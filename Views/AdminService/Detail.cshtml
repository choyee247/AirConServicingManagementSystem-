@model ServiceRecord
@{
    ViewData["Title"] = "Service Record Details";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Service Record Details - Technician Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f0f4f8;
            line-height: 1.5;
            padding: 1.25rem;
        }

        .details-container {
            max-width: 1100px;
            margin: 0 auto;
            width: 100%;
        }

        .modern-detail-card {
            background: #ffffff;
            border-radius: 32px;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.08), 0 1px 3px rgba(0, 0, 0, 0.02);
            overflow: hidden;
        }

        .detail-header {
            background: linear-gradient(135deg, #2c8c99 0%, #247a85 100%);
            padding: 1.5rem 2rem;
        }

            .detail-header h4 {
                font-size: 1.7rem;
                font-weight: 600;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 12px;
                color: white;
            }

                .detail-header h4 i {
                    font-size: 1.8rem;
                }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.3rem 1rem;
            border-radius: 40px;
            font-size: 0.8rem;
            font-weight: 600;
            background: #eef2ff;
            color: #2c8c99;
        }

        .detail-body {
            padding: 2rem;
        }

        .info-section {
            margin-bottom: 1.8rem;
            background: #fafcff;
            border-radius: 24px;
            padding: 1.2rem 1.5rem;
            border: 1px solid #edf2f7;
        }

        .section-title {
            font-size: 1.2rem;
            font-weight: 700;
            color: #1a2c3e;
            margin-bottom: 1.2rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            border-left: 4px solid #2c8c99;
            padding-left: 0.9rem;
        }

            .section-title i {
                color: #2c8c99;
            }

        .info-grid {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .info-row {
            display: flex;
            flex-wrap: wrap;
            align-items: baseline;
            gap: 0.5rem;
        }

        .info-label {
            font-weight: 700;
            min-width: 110px;
            color: #334e68;
            font-size: 0.9rem;
        }

        .info-value {
            color: #1f2d3d;
            font-weight: 500;
            flex: 1;
            word-break: break-word;
        }

        .alert-modern {
            padding: 1rem 1.2rem;
            border-radius: 20px;
            margin-top: 0.5rem;
            margin-bottom: 1rem;
            font-size: 0.95rem;
            border-left: 4px solid;
        }

        .alert-problem {
            border-left-color: #e53e3e;
            background: #fff5f5;
            color: #9b2c2c;
        }

        .alert-repair {
            border-left-color: #38a169;
            background: #f0fff4;
            color: #276749;
        }

        .alert-parts {
            border-left-color: #ed8936;
            background: #fffaf0;
            color: #9c4221;
        }

        .alert-note {
            border-left-color: #3182ce;
            background: #ebf8ff;
            color: #2c5282;
        }

        .alert-modern i {
            margin-right: 10px;
        }

        .soft-divider {
            height: 1px;
            background: linear-gradient(to right, #e2e8f0, transparent);
            margin: 1.2rem 0;
        }

        .next-service-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            background: #eef9ff;
            padding: 0.5rem 1.2rem;
            border-radius: 60px;
            font-weight: 600;
            font-size: 0.9rem;
            color: #2c8c99;
        }

        .back-button {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            background: white;
            border: 1.5px solid #2c8c99;
            color: #2c8c99;
            padding: 0.6rem 1.4rem;
            border-radius: 40px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

            .back-button:hover {
                background: #2c8c99;
                color: white;
            }

        @@media (max-width: 768px) {
            body {
                padding: 0.8rem;
            }

            .detail-body {
                padding: 1.2rem;
            }

            .detail-header {
                padding: 1rem 1.2rem;
            }

                .detail-header h4 {
                    font-size: 1.4rem;
                }

            .info-label {
                min-width: 100%;
            }

            .info-row {
                flex-direction: column;
                gap: 0.25rem;
            }

            .info-value {
                padding-left: 0.5rem;
                border-left: 2px solid #e2e8f0;
            }
        }
    </style>
</head>
<body>
    <div class="details-container">
        <div class="modern-detail-card">
            <div class="detail-header">
                <h4>
                    <i class="fas fa-clipboard-list"></i>
                    Service Record Details
                    <span style="font-size: 0.8rem; font-weight: 400; margin-left: auto; background: rgba(255,255,255,0.2); padding: 5px 12px; border-radius: 50px;">
                        <i class="fas fa-id-card"></i> Technician View
                    </span>
                </h4>
            </div>
            <div class="detail-body">
                <!-- CUSTOMER INFO - NOW USING @Model -->
                <div class="info-section">
                    <div class="section-title">
                        <i class="fas fa-user-circle"></i> Customer Information
                    </div>
                    <div class="info-grid">
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-user"></i> Full Name:</span>
                            <span class="info-value">@Model.Customer.Name</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-phone-alt"></i> Phone:</span>
                            <span class="info-value">@Model.Customer.Phone</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-map-marker-alt"></i> Address:</span>
                            <span class="info-value">@Model.Customer.Address</span>
                        </div>
                    </div>
                </div>

                <!-- AIRCON INFO -->
                <div class="info-section">
                    <div class="section-title">
                        <i class="fas fa-wind"></i> Air Conditioning Unit
                    </div>
                    <div class="info-grid">
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-microchip"></i> Unit Type:</span>
                            <span class="info-value">@Model.AirConUnit.AirConType / @Model.AirConUnit.CapacityHp Hp</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-barcode"></i> Serial Number:</span>
                            <span class="info-value">@Model.AirConUnit.Brand.BrandName - @Model.AirConUnit.Model.ModelName</span>
                        </div>
                    </div>
                </div>

                <!-- SERVICE INFO -->
                <div class="info-section">
                    <div class="section-title">
                        <i class="fas fa-tools"></i> Service Information
                    </div>
                    <div class="info-grid">
                        <div class="info-row">
                            <span class="info-label"><i class="far fa-calendar-check"></i> Service Date:</span>
                            <span class="info-value">@(Model.ServiceDate?.ToString("dd/MM/yyyy") ?? "N/A")</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-chart-line"></i> Status:</span>
                            <span class="info-value">
                                <span class="status-badge">
                                    <i class="fas fa-check-circle"></i> @Model.Status
                                </span>
                            </span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-concierge-bell"></i> Service Type:</span>
                            <span class="info-value">@Model.ServiceType</span>
                        </div>
                    </div>

                    <div class="soft-divider"></div>

                    <!-- PROBLEM FOUND -->
                    <div class="info-row" style="margin-bottom: 0.75rem;">
                        <span class="info-label"><i class="fas fa-exclamation-triangle"></i> Problem Found:</span>
                    </div>
                    <div class="alert-modern alert-problem">
                        <i class="fas fa-search"></i>
                        @Model.ProblemFound
                    </div>

                    <!-- REPAIR ACTION -->
                    <div class="info-row" style="margin-bottom: 0.75rem;">
                        <span class="info-label"><i class="fas fa-screwdriver-wrench"></i> Repair Action:</span>
                    </div>
                    <div class="alert-modern alert-repair">
                        <i class="fas fa-wrench"></i>
                        @Model.RepairAction
                    </div>

                    <!-- PARTS REPLACED -->
                    <div class="info-row" style="margin-bottom: 0.75rem;">
                        <span class="info-label"><i class="fas fa-microchip"></i> Parts Replaced:</span>
                    </div>
                    <div class="alert-modern alert-parts">
                        <i class="fas fa-cogs"></i>
                        @Model.PartsReplaced
                    </div>

                    <!-- TECHNICIAN NOTE -->
                    <div class="info-row" style="margin-bottom: 0.75rem;">
                        <span class="info-label"><i class="fas fa-pen-alt"></i> Technician Note:</span>
                    </div>
                    <div class="alert-modern alert-note">
                        <i class="fas fa-sticky-note"></i>
                        @Model.TechnicianNote
                    </div>

                    <div class="soft-divider"></div>

                    <!-- NEXT SERVICE DUE -->
                    <div class="info-row">
                        <span class="info-label"><i class="far fa-calendar-plus"></i> Next Service Due:</span>
                        <span class="info-value">
                            <div class="next-service-chip">
                                <i class="fas fa-calendar-alt"></i>
                                @(Model.NextServiceDue?.ToString("dd/MM/yyyy") ?? "Not scheduled")
                            </div>
                        </span>
                    </div>
                </div>

                <div style="display: flex; justify-content: flex-end; margin-top: 0.5rem;">
                    <a href="@Url.Action("Index", "Technician")" class="back-button">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
     
    </div>
</body>
</html>