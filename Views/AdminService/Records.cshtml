@model List<AirConServicingManagementSystem.Models.ServiceRecord>

@{
    ViewData["Title"] = "Service Records";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    :root {
        --primary-color: #2c8c99;
        --primary-dark: #24737d;
        --light-bg: #f4fbfc;
        --border-color: #e4eef0;
    }

    body {
        background: #f7f9fb;
    }

    .page-title {
        color: var(--primary-color);
        font-weight: 700;
        margin: 0;
    }

    .modern-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    }

    /* .search-box {
        border-radius: 14px;
        overflow: hidden;
        background: white;
        box-shadow: 0 4px 14px rgba(0,0,0,0.05);
    }

        .search-box .form-control {
            border: none;
            padding: 14px;
            box-shadow: none;
        }

    .search-btn {
        background: var(--primary-color);
        color: white;
        border: none;
        padding: 0 24px;
        font-weight: 600;
    }

        .search-btn:hover {
            background: var(--primary-dark);
            color: white;
        }

    .reset-btn {
        border: none;
        padding: 0 20px;
    } */

    .search-container {
        width: 100%;
    }

    .modern-search-box {
        background: #ffffff;
        border-radius: 18px;
        padding: 12px 14px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        border: 1px solid #eef3f4;
        transition: 0.3s ease;
    }

        .modern-search-box:focus-within {
            border-color: #2c8c99;
            box-shadow: 0 10px 30px rgba(44,140,153,0.18);
        }

    .search-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: rgba(44,140,153,0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2c8c99;
        font-size: 18px;
    }

    .modern-search-input {
        flex: 1;
        border: none;
        outline: none;
        font-size: 15px;
        background: transparent;
        color: #333;
    }

        .modern-search-input::placeholder {
            color: #9aa7ad;
        }

    .modern-search-btn {
        background: #2c8c99;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 10px 22px;
        font-weight: 600;
        transition: 0.25s ease;
    }

        .modern-search-btn:hover {
            background: #257782;
            color: white;
            transform: translateY(-1px);
        }

    .modern-reset-btn {
        background: #f1f5f6;
        color: #555;
        border: none;
        border-radius: 12px;
        padding: 10px 20px;
        font-weight: 600;
        transition: 0.25s ease;
    }

        .modern-reset-btn:hover {
            background: #e2ebed;
            color: #222;
        }

    .table thead {
        background: var(--primary-color);
        color: white;
    }

        .table thead th {
            border: none;
            padding: 16px;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: .3px;
        }

    .table tbody td {
        padding: 16px;
        vertical-align: middle;
        border-color: var(--border-color);
    }

    .table tbody tr:hover {
        background: var(--light-bg);
        transition: 0.2s ease;
    }

    .status-completed {
        background: #d1f5df;
        color: #198754;
        padding: 7px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
    }

    .status-progress {
        background: rgba(44, 140, 153, 0.12);
        color: var(--primary-color);
        padding: 7px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-complete {
        background: var(--primary-color);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 7px 14px;
        font-size: 13px;
        font-weight: 600;
        transition: 0.2s;
    }

        .btn-complete:hover {
            background: var(--primary-dark);
            color: white;
            transform: translateY(-1px);
        }

    .btn-delete {
        border-radius: 10px;
        padding: 7px 14px;
        font-size: 13px;
        font-weight: 600;
    }

    .table-responsive {
        border-radius: 18px;
    }

    .action-btn {
        border: none;
        border-radius: 12px;
        padding: 8px 14px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.25s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.06);
    }

        .action-btn i {
            font-size: 14px;
        }

    /* Complete button */
    .complete-btn {
        background: linear-gradient(135deg, #2c8c99, #36a9b8);
        color: white;
    }

        .complete-btn:hover {
            background: linear-gradient(135deg, #257782, #2c8c99);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(44, 140, 153, 0.25);
        }

    /* Delete button */
    .delete-btn {
        background: linear-gradient(135deg, #dc3545, #f05b6a);
        color: white;
    }

        .delete-btn:hover {
            background: linear-gradient(135deg, #bb2d3b, #dc3545);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(220, 53, 69, 0.25);
        }

    /* Completed badge */
    .status-done {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        border-radius: 30px;
        background: #d1f5df;
        color: #198754;
        font-size: 13px;
        font-weight: 600;
    }

        .status-done i {
            font-size: 14px;
        }
</style>

<div class="container py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title">Service Records</h2>
            <small class="text-muted">
                Manage all aircon servicing activities
            </small>
        </div>
    </div>

    <div class="search-container mb-4">

        <form method="get">

            <div class="modern-search-box">

                <!-- Search Icon -->
                <div class="search-icon">
                    <i class="fa fa-search"></i>
                </div>

                <!-- Input -->
                <input type="text"
                       name="search"
                       value="@ViewData["CurrentFilter"]"
                       class="modern-search-input"
                       placeholder="Search customer, technician, service type..." />

                <!-- Buttons -->
                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn modern-search-btn">
                        Search
                    </button>

                    <a href="/AdminService/Records"
                       class="btn modern-reset-btn">
                        Reset
                    </a>

                </div>

            </div>

        </form>

    </div>

    <!-- TABLE CARD -->
    <div class="modern-card">

        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Technician</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Type</th>
                        <th>Next Service</th>
                        <th width="210">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <strong>@item.Customer?.Name</strong>
                                </td>

                                <td>
                                    @item.Technician?.Name
                                </td>

                                <td>
                                    @item.ServiceDate?.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    @if (item.Status == "Completed")
                                    {
                                        <span class="status-completed">
                                            Completed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-progress">
                                            In Progress
                                        </span>
                                    }
                                </td>

                                <td>
                                    @item.ServiceType
                                </td>

                                <td>
                                    @(item.NextServiceDue?.ToString("dd MMM yyyy") ?? "-")
                                </td>

                                <td>
                                    <div class="d-flex align-items-center gap-2 flex-wrap">

                                        @* COMPLETE BUTTON *@
                                        @if (item.Status != "Completed")
                                        {
                                            <form asp-action="Complete"
                                                  asp-controller="TechnicianService"
                                                  method="post"
                                                  onsubmit="return confirm('Are you sure you want to mark this service as completed?');">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="id"
                                                       value="@item.ServiceRequestId" />

                                                <button type="submit" class="action-btn complete-btn">
                                                    <i class="fa fa-check-circle"></i>
                                                    <span>Complete</span>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="status-done">
                                                <i class="fa fa-check-circle"></i>
                                                Done
                                            </span>
                                        }

                                        @* DELETE BUTTON *@
                                        <form asp-action="Delete"
                                              method="post"
                                              onsubmit="return confirm('Are you sure you want to delete this record?');">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="id"
                                                   value="@item.Id" />

                                            <button type="submit" class="action-btn delete-btn">
                                                <i class="fa fa-trash"></i>
                                                <span>Delete</span>
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                No service records found.
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>