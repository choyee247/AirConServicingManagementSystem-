@model List<AirConServicingManagementSystem.Models.ServiceRecord>

@{
    ViewData["Title"] = "Service Records";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
}
<style>
    :root {
        --theme: #2c8c99;
    }

    body {
        background: #f5f8fb;
    }

    .modern-input {
        border-radius: 12px;
        padding: 12px;
        border: 1px solid #ddd;
    }

        .modern-input:focus {
            border-color: var(--theme);
            box-shadow: 0 0 0 .15rem rgba(44,140,153,.2);
        }

    .btn-theme {
        background: var(--theme);
        color: white;
        border-radius: 12px;
        padding: 10px;
    }

        .btn-theme:hover {
            background: #257681;
            color: white;
        }

    .modern-table thead {
        background: #f8f9fa;
    }

    .modern-table th {
        font-weight: 700;
        padding: 18px;
    }

    .modern-table td {
        padding: 18px;
        vertical-align: middle;
    }

    .modern-table tbody tr {
        transition: .25s;
    }

        .modern-table tbody tr:hover {
            background: #eef9fa;
            transform: scale(1.002);
        }

    .badge-status-success {
        background: #d4edda;
        color: #198754;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
    }

    .badge-status-warning {
        background: #fff3cd;
        color: #856404;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
    }

    .btn-detail {
        background: #2c8c99;
        color: white;
        border-radius: 10px;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
        border-radius: 10px;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        border-radius: 18px;
    }
</style>
<div class="container-fluid py-4">

    <div class="row mb-4">

        <div class="col-md-8">

            <h2 class="fw-bold mb-1" style="color:#2c8c99;">
                <i class="fas fa-history me-2"></i>
                Service Records
            </h2>

            <p class="text-muted mb-0">
                View completed maintenance history and service reports
            </p>

        </div>

        <div class="col-md-4">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-body text-center">

                    <h3 class="fw-bold mb-0 text-success">
                        @Model.Count()
                    </h3>

                    <small class="text-muted">
                        Total Records
                    </small>

                </div>

            </div>

        </div>

    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">

        <div class="card-body">

            <div class="row">

                <div class="col-md-5">

                    <input type="text"
                           class="form-control modern-input"
                           placeholder="Search customer...">

                </div>

                <div class="col-md-3">

                    <button class="btn btn-theme w-100">

                        <i class="fas fa-search"></i>

                        Search

                    </button>

                </div>

            </div>

        </div>

    </div>

    <div class="card border-0 shadow rounded-4 overflow-hidden">

        <div class="card-header border-0 text-white"
             style="background:#2c8c99;">

            <h5 class="mb-0">

                <i class="fas fa-tools me-2"></i>

                Completed Services

            </h5>

        </div>

        <div class="table-responsive">

            <table class="table modern-table align-middle mb-0">

                <thead>

                    <tr>

                        <th>Customer</th>

                        <th>Technician</th>

                        <th>Air Conditioner</th>

                        <th>Service Date</th>

                        <th>Status</th>

                        <th>Service Type</th>

                        <th>Next Service</th>

                        <th class="text-center">
                            Action
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {

                        <tr>

                            <td>

                                <div>

                                    <div class="fw-bold">

                                        @item.Customer?.Name

                                    </div>

                                    <small class="text-muted">

                                        Customer

                                    </small>

                                </div>

                            </td>

                            <td>

                                <span class="fw-semibold">

                                    @item.Technician?.Name

                                </span>

                            </td>

                            <td>

                                @if (item.AirConUnit != null)
                                {

                                    <div>

                                        <strong>

                                            @item.AirConUnit.Brand.BrandName

                                        </strong>

                                        <br>

                                        <small class="text-muted">

                                            @item.AirConUnit.Model.ModelName

                                        </small>

                                    </div>

                                }
                                else
                                {

                                    <span class="text-danger">

                                        Not Assigned

                                    </span>

                                }

                            </td>

                            <td>

                                @item.CreatedAt?.ToString("dd MMM yyyy")

                            </td>

                            <td>

                                @if (item.Status == "Completed")
                                {

                                    <span class="badge-status-success">

                                        Completed

                                    </span>

                                }
                                else
                                {

                                    <span class="badge-status-warning">

                                        In Progress

                                    </span>

                                }

                            </td>

                            <td>

                                @item.ServiceType

                            </td>

                            <td>

                                @(item.NextServiceDue?.ToString("dd MMM yyyy") ?? "-")

                            </td>

                            <td>

                                <div class="d-flex justify-content-center gap-2">

                                    <a asp-controller="ServiceRequest"
                                       asp-action="Details"
                                       asp-route-appointmentId="@item.ServiceRequest.Appointment.AppointmentId"
                                       class="btn btn-sm btn-detail">

                                        <i class="fas fa-eye"></i>

                                    </a>
                                  
                                    <form asp-action="Delete"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="id"
                                               value="@item.ServiceRequestId" />

                                        <button class="btn btn-sm btn-delete">

                                            <i class="fas fa-trash"></i>

                                        </button>

                                    </form>

                                </div>

                            </td>

                        </tr>

                    }

                    @if (!Model.Any())
                    {

                        <tr>

                            <td colspan="8">

                                <div class="text-center py-5">

                                    <i class="fas fa-folder-open fa-4x text-muted mb-3"></i>

                                    <h5>No Service Records</h5>

                                    <p class="text-muted">

                                        No completed services available.

                                    </p>

                                </div>

                            </td>

                        </tr>

                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
