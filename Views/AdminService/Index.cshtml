@model IEnumerable<AirConServicingManagementSystem.Models.ServiceRequest>

@{
    ViewData["Title"] = "Start Service";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-4">

    <div class="card shadow-sm rounded-3 border-0">

        <!-- HEADER -->
        <div class="card-header bg-white d-flex justify-content-between align-items-center">

            <div>
                <h3 style="color:#2c8c99;font-weight:700;">
                    Appointment Schedule
                </h3>
                <p class="text-muted mb-0">
                    Technician Work Dashboard
                </p>
            </div>

        </div>

        <!-- TABLE -->
        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Customer</th>
                            <th>Location</th>
                            <th>Schedule Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <!-- ID -->
                                <td class="fw-bold">
                                    @item.ServiceId
                                </td>

                                <!-- CUSTOMER -->
                                <td>
                                    @item.Customer?.Name
                                </td>

                                <!-- LOCATION -->
                                <td>
                                    @item.Location
                                </td>

                                <!-- DATE -->
                                <td>
                                    @item.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                </td>

                                <!-- STATUS -->
                                <td>
                                    <span class="badge
                                        @(item.Status == "Pending" ? "bg-warning text-dark" :
                                          item.Status == "Assigned" ? "bg-info" :
                                          item.Status == "In Progress" ? "bg-primary" :
                                          item.Status == "Completed" ? "bg-success" :
                                          "bg-secondary")">

                                        @item.Status
                                    </span>
                                </td>

                                <!-- ACTION -->
                                <td class="d-flex gap-1 flex-wrap">

                                    <!-- START SERVICE (Appointment → ServiceRequest) -->
                                    @if (item.Status == "Pending")
                                    {
                                        <a asp-controller="ServiceRequest"
                                           asp-action="Create"
                                           asp-route-appointmentId="@item.ServiceId"
                                           class="btn btn-sm text-white"
                                           style="background:#2c8c99;">
                                            Start Service
                                        </a>
                                    }

                                   

                                    <!-- AIRCON VIEW -->
                                    <a asp-controller="AirConUnit"
                                       asp-action="Index"
                                       asp-route-customerId="@item.CustomerId"
                                       class="btn btn-sm btn-outline-secondary">
                                        AirCon
                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-4 text-muted">
                    No appointments found.
                </div>
            }

        </div>

    </div>

</div>