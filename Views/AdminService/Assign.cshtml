@model AirConServicingManagementSystem.Models.Appointment

@{
    ViewData["Title"] = "Assign Technician";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <div class="card shadow-sm rounded-3">

        <!-- HEADER -->
        <div class="card-header bg-white">
            <h3 class="mb-0" style="color:#2c8c99; font-weight:700;">
                Assign Technician
            </h3>
            <p class="text-muted mb-0">
                Assign a technician for this appointment
            </p>
        </div>

        <div class="card-body">

            <div class="row g-4">

                <!-- LEFT: APPOINTMENT DETAILS -->
                <div class="col-md-6">

                    <div class="p-3 border rounded-3">

                        <h5 style="color:#2c8c99;">Appointment Details</h5>
                        <hr />

                        <div class="mb-2">
                            <strong>Customer:</strong>
                            <p class="mb-1">
                                @Model.Customer?.Name 
                            </p>
                        </div>

                        <div class="mb-2">
                            <strong>Location:</strong>
                            <p class="mb-1">
                                @Model.Location 
                            </p>
                        </div>

                        <div class="mb-2">
                            <strong>Scheduled Date:</strong>
                            <p class="mb-1">
                                @Model.ScheduledDate.ToString("dd-MM-yyyy HH:mm")
                            </p>
                        </div>

                        <div class="mb-2">
                            <strong>Status:</strong>
                            <p class="mb-1">
                                <span class="badge bg-warning text-dark">
                                    @Model.Status
                                </span>
                            </p>
                        </div>

                    </div>

                </div>

                <!-- RIGHT: ASSIGN FORM -->
                <div class="col-md-6">

                    <div class="p-3 border rounded-3">

                        <h5 style="color:#2c8c99;">Select Technician</h5>
                        <hr />

                        <form asp-action="Assign" method="post">

                            <!-- IMPORTANT FIX -->
                            <input type="hidden" name="id" value="@Model.AppointmentId" />

                            <div class="mb-3">
                                <label class="form-label">Technician</label>

                                <select name="technicianId"
                                        class="form-select"
                                        required>

                                    <option value="">-- Select Technician --</option>

                                    @foreach (var tech in (List<AirConServicingManagementSystem.Models.Technician>)ViewBag.Technicians)
                                    {
                                        <option value="@tech.TechnicianId">
                                            @tech.Name (@tech.PhoneNumber)
                                        </option>
                                    }

                                </select>
                            </div>

                            <button type="submit"
                                    class="btn w-100 text-white"
                                    style="background:#2c8c99;">
                                Assign Technician
                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>