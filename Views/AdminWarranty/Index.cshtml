@model IEnumerable<AirConServicingManagementSystem.Models.Warranty>

@{
    ViewData["Title"] = "Warranty List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    body {
        background: #f4f8fa;
    }

    .page-title {
        color: #2c8c99;
        font-weight: 700;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .btn-add {
        background: #2c8c99;
        border: none;
        color: #fff;
        border-radius: 25px;
        padding: 8px 16px;
        transition: .3s;
    }

        .btn-add:hover {
            background: #226f7a;
            color: #fff;
        }

    .card-box {
        background: #fff;
        border-radius: 18px;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg,#2c8c99,#45a8b5);
        color: #fff;
        padding: 16px 20px;
        font-weight: 600;
    }

    .table thead {
        background: #eef7f8;
    }

        .table thead th {
            color: #2c8c99;
            font-weight: 600;
            border: none;
            padding: 14px;
        }

    .table td {
        padding: 14px;
        vertical-align: middle;
        border-top: 1px solid #edf2f4;
    }

    .table tbody tr:hover {
        background: #f8fcfc;
    }

    .badge-active {
        background: rgba(44,140,153,.15);
        color: #2c8c99;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-expired {
        background: #ffe5e5;
        color: #d63031;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-edit {
        background: #f39c12;
        border: none;
        color: #fff;
        border-radius: 20px;
        padding: 5px 12px;
        font-size: 13px;
    }

        .btn-edit:hover {
            background: #d68910;
            color: #fff;
        }

    .text-muted-small {
        color: #636e72;
        font-size: 14px;
    }
</style>

<div class="container py-4">

    <div class="top-bar">
        <h3 class="page-title">@ViewData["Title"]</h3>

        <a asp-action="Create" class="btn btn-add">
            + Add Warranty
        </a>
    </div>

    <div class="card-box">

        <div class="card-header">
            Warranty Records
        </div>

        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>AirCon</th>
                        <th>Customer</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int i = 1;
                        foreach (var w in Model)
                        {
                            <tr>
                                <td>@i</td>

                                <td>
                                    <strong>@w.AirCon?.Brand?.BrandName</strong> -
                                    <span class="text-muted-small">@w.AirCon?.Model?.ModelName</span>
                                </td>

                                <td>@w.AirCon?.Customer?.Name</td>

                                <td>@w.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@w.EndDate.ToString("yyyy-MM-dd")</td>

                                <td>
                                    @if (w.IsActive)
                                    {
                                        <span class="badge-active">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-expired">Expired</span>
                                    }
                                </td>

                                <td>
                                    <a asp-action="Edit"
                                       asp-route-id="@w.WarrantyId"
                                       class="btn btn-edit">
                                        Edit
                                    </a>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                No warranty found
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>
</div>