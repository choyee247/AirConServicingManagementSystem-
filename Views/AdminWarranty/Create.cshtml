@model AirConServicingManagementSystem.Models.Warranty

@{
    ViewData["Title"] = "Add Warranty";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">Add Warranty</h4>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label">AirCon</label>
                    <select asp-for="AirConId" class="form-select" required>
                        <option value="">-- Select AirCon --</option>
                        @if (ViewBag.AirCons != null)
                        {
                            foreach (var a in ViewBag.AirCons)
                            {
                                <option value="@a.Id">
                                    @a.Brand.BrandName - @a.Model.ModelName
                                </option>
                            }
                        }
                    </select>

                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Start Date</label>
                        <input asp-for="StartDate" type="date" class="form-control" required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">End Date</label>
                        <input asp-for="EndDate" type="date" class="form-control" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save"></i> Save
                </button>

                <a asp-action="Index" class="btn btn-secondary ms-2">
                    <i class="fas fa-arrow-left"></i> Back
                </a>
            </form>
        </div>
    </div>
</div>
