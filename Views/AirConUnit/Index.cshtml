@model IEnumerable<AirConServicingManagementSystem.Models.AirConUnit>

@{
    ViewData["Title"] = "My AirCon Units";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold" style="color: #2c8c99;">@ViewData["Title"]</h3>
        <a asp-action="Create" class="btn text-white" style="background-color: #2c8c99; border: none;">
            <i class="fas fa-plus me-2"></i> Add New Aircon
        </a>
    </div>

    <!-- Search and Filter Section -->
    <div class="card shadow-sm mb-4" style="border: 1px solid #2c8c99;">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <!-- Search -->
                <div class="col-md-3">
                    <label class="form-label" style="color: #2c8c99;">Search</label>
                    <div class="input-group">
                        <input type="text" id="searchInput" class="form-control"
                               placeholder="Search by brand, model, serial..."
                               style="border: 1px solid #2c8c99;">
                        <button class="btn"
                                style="background-color: #2c8c99; color: white;"
                                type="button"
                                id="searchButton">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>

                <!-- Capacity -->
                <div class="col-md-2">
                    <label class="form-label" style="color: #2c8c99;">Capacity</label>
                    <select id="capacityFilter" class="form-select" style="border: 1px solid #2c8c99;">
                        <option value="">All HP</option>
                        <option value="0.5">0.5 HP</option>
                        <option value="1">1 HP</option>
                        <option value="1.5">1.5 HP</option>
                        <option value="2">2 HP</option>
                        <option value="2.5">2.5 HP</option>
                        <option value="3">3 HP</option>
                    </select>
                </div>

                <!-- Brand -->
                <div class="col-md-2">
                    <label class="form-label" style="color: #2c8c99;">Brand</label>
                    <select id="brandFilter" class="form-select" style="border: 1px solid #2c8c99;">
                        <option value="">All Brands</option>
                        @if (Model != null)
                        {
                            var brands = Model
                            .Where(a => a.Brand != null && !string.IsNullOrEmpty(a.Brand.BrandName))
                            .Select(a => a.Brand.BrandName)
                            .Distinct()
                            .OrderBy(b => b);

                            foreach (var brand in brands)
                            {
                                <option value="@brand">@brand</option>
                            }
                        }
                    </select>
                </div>

                <!-- AirCon Type -->
                <div class="col-md-3">
                    <label class="form-label" style="color: #2c8c99;">AirCon Type</label>
                    <select id="typeFilter" class="form-select" style="border: 1px solid #2c8c99;">
                        <option value="">All Types</option>
                        <option value="Window">Window</option>
                        <option value="Stand">Stand</option>
                        <option value="Wall Split">Wall Split</option>
                        <option value="Cassette">Cassette</option>
                        <option value="Ceiling Duct">Ceiling Duct</option>
                        <option value="Floor Standing">Floor Standing</option>
                    </select>
                </div>

                <!-- Clear -->
                <div class="col-md-2">
                    <button class="btn w-100"
                            style="background-color: #f8f9fa; border: 1px solid #2c8c99; color: #2c8c99;"
                            id="clearFilters">
                        <i class="fas fa-times me-2"></i>Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Section -->
    <div class="card shadow-sm" style="border: 1px solid #2c8c99;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background-color: #2c8c99; color: white;">
                        <tr>
                            <th>#</th>
                            <th>Brand</th>
                            <th>Model</th>
                            <th>Serial Number</th>
                            <th>AirCon Type</th>
                            <th>Capacity (HP)</th>
                            <th>Installation Date</th>
                            <th>Warranty</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="airconTableBody">
                        @if (Model != null && Model.Any())
                        {
                            int index = 1;
                            foreach (var aircon in Model)
                            {
                                <tr class="aircon-row"
                                    data-brand="@aircon.Brand?.BrandName?.ToLower()"
                                    data-model="@aircon.Model?.ModelName?.ToLower()"
                                    data-serial="@aircon.SerialNumber?.ToLower()"
                                    data-capacity="@aircon.CapacityHp"
                                    data-type="@aircon.AirConType?.ToLower()">

                                    <td class="fw-bold">@index</td>
                                    <td>@aircon.Brand?.BrandName</td>
                                    <td>@aircon.Model?.ModelName</td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @aircon.SerialNumber
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @(string.IsNullOrEmpty(aircon.AirConType) ? "N/A" : aircon.AirConType)
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge"
                                              style="background-color: #e6f7f9; color: #2c8c99; border: 1px solid #2c8c99;">
                                            @aircon.CapacityHp HP
                                        </span>
                                    </td>

                                    <td>
                                        @(aircon.InstallationDate.HasValue
                                            ? aircon.InstallationDate.Value.ToString("yyyy-MM-dd")
                                            : "N/A")
                                    </td>

                                    <td>
                                        @if (aircon.Warranty != null)
                                        {
                                            if (aircon.Warranty.StartDate <= DateTime.Now &&
                                            aircon.Warranty.EndDate >= DateTime.Now)
                                            {
                                                <i class="fas fa-check-circle text-success me-1"></i>
                                                <span class="text-success fw-bold">Under Warranty</span>
                                                <br />
                                                <small class="text-muted">
                                                    Exp: @aircon.Warranty.EndDate.ToString("yyyy-MM-dd")
                                                </small>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-circle text-danger me-1"></i>
                                                <span class="text-danger fw-bold">Expired</span>
                                                <br />
                                                <small class="text-muted">
                                                    Exp: @aircon.Warranty.EndDate.ToString("yyyy-MM-dd")
                                                </small>
                                            }
                                        }
                                        else
                                        {
                                            <i class="fas fa-minus-circle text-secondary me-1"></i>
                                            <span class="text-secondary fw-bold">No Warranty</span>
                                        }
                                    </td>

                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details"
                                               asp-route-id="@aircon.Id"
                                               class="btn btn-sm text-white me-1"
                                               style="background-color: #2c8c99;"
                                               title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>

                                            <a asp-action="Edit"
                                               asp-route-id="@aircon.Id"
                                               class="btn btn-sm text-white me-1"
                                               style="background-color: #ffc107;"
                                               title="Edit">
                                                <i class="fas fa-edit"></i>
                                            </a>

                                            <a asp-action="Delete"
                                               asp-route-id="@aircon.Id"
                                               class="btn btn-sm text-white"
                                               style="background-color: #dc3545;"
                                               onclick="return confirm('Are you sure you want to delete this aircon?');"
                                               title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-4">
                                    <div class="text-muted">
                                        <i class="fas fa-wind fa-3x mb-3"
                                           style="color: #d1ecf1;"></i>
                                        <h5 style="color: #2c8c99;">No aircon units found</h5>
                                        <p>Add your first aircon unit by clicking the "Add New Aircon" button</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const rows = $('.aircon-row');

            function performSearch() {
                const searchTerm = $('#searchInput').val().toLowerCase().trim();
                const capacityFilter = $('#capacityFilter').val();
                const brandFilter = $('#brandFilter').val().toLowerCase().trim();
                const typeFilter = $('#typeFilter').val().toLowerCase().trim();

                rows.each(function () {
                    const row = $(this);
                    const brand = row.data('brand') || '';
                    const model = row.data('model') || '';
                    const serial = row.data('serial') || '';
                    const capacity = (row.data('capacity') || '').toString();
                    const type = row.data('type') || '';

                    const matchesSearch =
                        !searchTerm ||
                        brand.includes(searchTerm) ||
                        model.includes(searchTerm) ||
                        serial.includes(searchTerm);

                    const matchesCapacity =
                        !capacityFilter ||
                        capacity === capacityFilter;

                    const matchesBrand =
                        !brandFilter ||
                        brand.includes(brandFilter);

                    const matchesType =
                        !typeFilter ||
                        type === typeFilter;

                    if (matchesSearch && matchesCapacity && matchesBrand && matchesType) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            $('#searchButton').on('click', performSearch);

            $('#searchInput').on('keyup', function (e) {
                if (e.key === 'Enter') {
                    performSearch();
                }
            });

            $('#capacityFilter, #brandFilter, #typeFilter').on('change', performSearch);

            $('#clearFilters').on('click', function () {
                $('#searchInput').val('');
                $('#capacityFilter').val('');
                $('#brandFilter').val('');
                $('#typeFilter').val('');
                performSearch();
            });
        });
    </script>

    <style>
        .table-hover tbody tr:hover {
            background-color: rgba(44, 140, 153, 0.1) !important;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #2c8c99 !important;
            box-shadow: 0 0 0 0.25rem rgba(44, 140, 153, 0.25) !important;
        }
    </style>
}