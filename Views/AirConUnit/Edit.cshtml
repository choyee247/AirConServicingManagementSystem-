@model AirConServicingManagementSystem.Models.AirConUnit

@{
    ViewData["Title"] = "Edit Aircon";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
}

<div class="container-fluid">

    <div class="form-container">

        <!-- HEADER -->
        <div class="form-header">
            <i class="fas fa-edit"></i>
            <h3>Edit Air Conditioning Unit</h3>
        </div>

        <!-- INFO -->
        <div class="info-box">
            <i class="fas fa-info-circle"></i>
            Update the air conditioning unit details.
        </div>

        <form asp-action="Edit" method="post" id="editAirconForm">

            <input type="hidden" asp-for="Id" />

            <!-- CUSTOMER (READ ONLY like Create) -->
            <div class="form-section">

                <div class="section-title">
                    <i class="fas fa-user"></i> Customer Information
                </div>

                <div class="p-3 mt-3 rounded-3 border bg-light d-flex align-items-center">

                    <div class="rounded-circle d-flex justify-content-center align-items-center text-white fw-bold"
                         style="width:45px;height:45px;background:#2c8c99;">
                        @Model.Customer?.Name?.Substring(0, 1).ToUpper()
                    </div>

                    <div class="ms-3">
                        <div class="fw-bold">
                            @Model.Customer?.Name
                        </div>
                        <small class="text-muted">
                            <i class="fas fa-phone me-1"></i>
                            @Model.Customer?.Phone
                        </small>
                    </div>

                </div>

                <input type="hidden" asp-for="CustomerId" />

            </div>

            <!-- BRAND -->
            <div class="form-section">

                <div class="section-title">
                    <i class="fas fa-tag"></i> Brand Information
                </div>

                <div class="mb-3">
                    <label class="form-label">Brand</label>
                    <select asp-for="BrandId" class="form-select" id="BrandId">
                        <option value="">-- Select Brand --</option>
                        @foreach (var b in ViewBag.Brands)
                        {
                            <option value="@b.Id">@b.BrandName</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Model</label>
                    <select asp-for="ModelId" class="form-select" id="ModelId">
                        <option value="">-- Select Model --</option>
                        @foreach (var m in ViewBag.Models)
                        {
                            <option value="@m.Id">@m.ModelName</option>
                        }
                    </select>
                </div>

            </div>

            <!-- UNIT DETAILS -->
            <div class="form-section">

                <div class="section-title">
                    <i class="fas fa-cog"></i> Unit Details
                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">AirCon Type</label>
                        <select asp-for="AirConType" class="form-select">
                            <option value="">-- Select Type --</option>
                            <option>Window</option>
                            <option>Stand</option>
                            <option>Wall Split</option>
                            <option>Cassette</option>
                            <option>Ceiling Duct</option>
                            <option>Floor Standing</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Capacity (HP)</label>
                        <select asp-for="CapacityHp" class="form-select">
                            <option value="">-- Select HP --</option>
                            <option>0.5</option>
                            <option>1</option>
                            <option>1.5</option>
                            <option>2</option>
                            <option>2.5</option>
                            <option>3</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Installation Date</label>
                        <input asp-for="InstallationDate" type="date" class="form-control" />
                    </div>

                </div>

            </div>

            <!-- ACTIONS -->
            <div class="form-footer">

                <button type="submit" class="btn btn-custom">
                    <i class="fas fa-save"></i> Update Aircon
                </button>

                <a asp-action="Index" class="btn btn-secondary-custom ms-2">
                    Cancel
                </a>

            </div>

        </form>

    </div>
</div>