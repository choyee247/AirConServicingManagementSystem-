@model IEnumerable<AirConServicingManagementSystem.Models.AirConModel>
@{
    ViewData["Title"] = "Aircon Models";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm" style="border-top: 4px solid #2c8c99;">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0" style="color: #2c8c99;">
                        <i class="fas fa-snowflake me-2"></i>Aircon Models
                    </h4>
                    <p class="text-muted small mb-0 mt-1">Manage all air conditioner models in the system</p>
                </div>
                <a asp-action="CreateModel" class="btn text-white" style="background-color: #2c8c99; border-color: #2c8c99;">
                    <i class="fas fa-plus-circle me-2"></i>Add New Model
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light" style="background-color: #f8f9fa !important;">
                        <tr>
                            <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99;">ID</th>
                            <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99;">Brand</th>
                            <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99;">Model Name</th>
                            <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99;">HP</th>
                            <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99; text-align: center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid #eee; transition: background-color 0.2s;">
                                <td class="align-middle" style="padding: 1rem; font-weight: 500;">#@item.Id</td>
                                <td class="align-middle" style="padding: 1rem;">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0 me-3">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width: 36px; height: 36px; background-color: rgba(44, 140, 153, 0.1); color: #2c8c99;">
                                                <i class="fas fa-tag"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1">
                                            <span class="fw-semibold">@item.Brand.BrandName</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="align-middle" style="padding: 1rem;">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0 me-3">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width: 36px; height: 36px; background-color: rgba(44, 140, 153, 0.1); color: #2c8c99;">
                                                <i class="fas fa-snowflake"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1">
                                            <span class="fw-semibold">@item.ModelName</span>
                                            <div class="small text-muted">Model ID: @item.Id</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="align-middle" style="padding: 1rem;">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0 me-3">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width: 36px; height: 36px; background-color: rgba(44, 140, 153, 0.1); color: #2c8c99;">
                                                <i class="fas fa-bolt"></i>
                                            </div>
                                        </div>
                                       @*  <div class="flex-grow-1">
                                            <span class="fw-semibold">@item.Hp HP</span>
                                            <div class="small text-muted">Horsepower</div>
                                        </div> *@
                                    </div>
                                </td>
                                <td class="align-middle" style="padding: 1rem; text-align: center;">
                                    <div class="btn-group" role="group">
                                        <a asp-action="EditModel" asp-route-id="@item.Id"
                                           class="btn btn-sm d-flex align-items-center justify-content-center"
                                           style="background-color: rgba(44, 140, 153, 0.1); color: #2c8c99; border: 1px solid rgba(44, 140, 153, 0.3); margin-right: 0.25rem; padding: 0.375rem 0.75rem;">
                                            <i class="fas fa-edit me-1"></i>
                                            <span class="d-none d-md-inline">Edit</span>
                                        </a>
                                        <a asp-action="DeleteModel" asp-route-id="@item.Id"
                                           class="btn btn-sm d-flex align-items-center justify-content-center"
                                           style="background-color: rgba(220, 53, 69, 0.1); color: #dc3545; border: 1px solid rgba(220, 53, 69, 0.3); padding: 0.375rem 0.75rem;">
                                            <i class="fas fa-trash me-1"></i>
                                            <span class="d-none d-md-inline">Delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-3" style="color: #dee2e6;">
                        <i class="fas fa-snowflake" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="text-muted mb-2">No Models Found</h5>
                    <p class="text-muted mb-4">Add your first air conditioner model to get started</p>
                    <a asp-action="CreateModel" class="btn text-white" style="background-color: #2c8c99; border-color: #2c8c99;">
                        <i class="fas fa-plus-circle me-2"></i>Add First Model
                    </a>
                </div>
            }
        </div>

        <div class="card-footer bg-white py-3 border-top">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small">
                    <i class="fas fa-info-circle me-1" style="color: #2c8c99;"></i>
                    Showing <strong>@Model.Count()</strong> model@(Model.Count() != 1 ? "s" : "")
                </div>
                <div class="small text-muted">
                    <i class="fas fa-clock me-1"></i>
                    Updated just now
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Add hover effect to table rows
            const tableRows = document.querySelectorAll('tbody tr');
            tableRows.forEach(row => {
                row.addEventListener('mouseenter', function() {
                    this.style.backgroundColor = 'rgba(44, 140, 153, 0.03)';
                });

                row.addEventListener('mouseleave', function() {
                    this.style.backgroundColor = '';
                });
            });

            // Add click effect to action buttons
            const actionButtons = document.querySelectorAll('.btn-group a');
            actionButtons.forEach(button => {
                button.addEventListener('mousedown', function() {
                    this.style.transform = 'scale(0.95)';
                });

                button.addEventListener('mouseup', function() {
                    this.style.transform = '';
                });

                button.addEventListener('mouseleave', function() {
                    this.style.transform = '';
                });
            });

            // Format HP values
            const hpCells = document.querySelectorAll('td:nth-child(4) .fw-semibold');
            hpCells.forEach(cell => {
                const hpValue = cell.textContent.trim();
                if (hpValue && !hpValue.includes('HP')) {
                    cell.textContent = hpValue + ' HP';
                }
            });
        });
    </script>
}