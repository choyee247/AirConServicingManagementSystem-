                            <div class="summary-card-body">

                                <div>

                                    <div class="summary-label">
                                        Accepted
                                    </div>

                                    <div class="summary-subtext">
                                        In Progress
                                    </div>

                                </div>

                                <div class="summary-right">

                                    <div class="summary-icon accepted-icon">

                                        <svg width="22"
                                             height="22"
                                             viewBox="0 0 24 24"
                                             fill="#198754">

                                            <path d="M9 16.17L4.83 12L3.41 13.41L9 19L21 7Z" />

                                        </svg>

                                    </div>

                                    <div class="summary-count">
                                        @Model.AcceptedCount
                                    </div>

                                </div>

                            </div>

