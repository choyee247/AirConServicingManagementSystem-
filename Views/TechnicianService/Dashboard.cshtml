@model AirConServicingManagementSystem.ViewsModels.TechnicianDashboardVM

@{
    ViewData["Title"] = "Technician Dashboard";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";

    var totalTasks = Model.AssignedCount + Model.PendingCount + Model.AcceptedCount + Model.CompletedCount;

    var completionRate = totalTasks > 0
        ? (Model.CompletedCount * 100 / totalTasks)
        : 0;
}

@functions {
    string StatusStyle(string status)
    {
        return status switch
        {
            "Pending" => "background-color:#ffc107;color:#000;",
            "Assigned" => "background-color:#0dcaf0;color:#000;",
            "Accepted" => "background-color:#0d6efd;color:#fff;",
            "Completed" => "background-color:#198754;color:#fff;",
            "Rejected" => "background-color:#dc3545;color:#fff;",
            _ => "background-color:#6c757d;color:#fff;"
        };
    }
}

<div class="container-fluid dashboard-container">

    <!-- HEADER -->
    <div class="dashboard-header">

        <div>
            <h1 class="dashboard-title">
                Technician Dashboard
            </h1>

            <p class="dashboard-subtitle">
                Welcome to your service management panel
            </p>
        </div>

        <div class="dashboard-date">
            <div>@DateTime.Now.ToString("dd MMM yyyy")</div>
            <div>@DateTime.Now.ToString("hh:mm tt")</div>
        </div>

    </div>

    <!-- STATS -->
    <div class="row g-3 mb-4">

        <!-- Assigned -->
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dashboard-card">

                <div class="card-top">

                    <div>
                        <div class="card-label">
                            Assigned
                        </div>

                        <div class="card-number">
                            @Model.AssignedCount
                        </div>

                        <div class="card-text">
                            Tasks waiting
                        </div>
                    </div>

                    <div class="card-icon assigned-icon">

                        <svg width="22" height="22" viewBox="0 0 24 24" fill="#0dcaf0">
                            <path d="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3Z" />
                        </svg>

                    </div>

                </div>

            </div>
        </div>

        <!-- Pending -->
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dashboard-card">

                <div class="card-top">

                    <div>
                        <div class="card-label">
                            Pending
                        </div>

                        <div class="card-number">
                            @Model.PendingCount
                        </div>

                        <div class="card-text">
                            Awaiting action
                        </div>
                    </div>

                    <div class="card-icon pending-icon">

                        <svg width="22" height="22" viewBox="0 0 24 24" fill="#ffc107">
                            <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22Z" />
                        </svg>

                    </div>

                </div>

            </div>
        </div>

        <!-- Accepted -->
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dashboard-card">

                <div class="card-top">

                    <div>
                        <div class="card-label">
                            Accepted
                        </div>

                        <div class="card-number">
                            @Model.AcceptedCount
                        </div>

                        <div class="card-text">
                            In progress
                        </div>
                    </div>

                    <div class="card-icon accepted-icon">

                        <svg width="22" height="22" viewBox="0 0 24 24" fill="#198754">
                            <path d="M9 16.17L4.83 12L3.41 13.41L9 19L21 7Z" />
                        </svg>

                    </div>

                </div>

            </div>
        </div>

        <!-- Completed -->
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dashboard-card">

                <div class="card-top">

                    <div>
                        <div class="card-label">
                            Completed
                        </div>

                        <div class="card-number">
                            @Model.CompletedCount
                        </div>

                        <div class="card-text">
                            Finished tasks
                        </div>
                    </div>

                    <div class="card-icon completed-icon">

                        <svg width="22" height="22" viewBox="0 0 24 24" fill="#0d6efd">
                            <path d="M9 16.17L4.83 12L3.41 13.41L9 19L21 7Z" />
                        </svg>

                    </div>

                </div>

            </div>
        </div>

    </div>

    <!-- PROGRESS + QUICK ACTION -->
    <div class="row g-3 mb-4">

        <!-- Progress -->
        <div class="col-12 col-lg-8">

            <div class="dashboard-card h-100">

                <div class="section-title">
                    Task Progress Summary
                </div>

                <div class="mb-3">

                    <div class="d-flex justify-content-between mb-2">
                        <small>Completion Rate</small>
                        <small class="fw-bold">@completionRate%</small>
                    </div>

                    <div class="custom-progress">
                        <div class="custom-progress-bar"
                             style="width:@completionRate%">
                        </div>
                    </div>

                </div>

               @*  <div class="row g-3 mt-1">

                    <!-- Assigned -->
