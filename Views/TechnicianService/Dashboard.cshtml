                                    <div class="summary-label">
                                        Completed
                                    </div>

                                    <div class="summary-subtext">
                                        Finished Tasks
                                    </div>

                                </div>

                                <div class="summary-right">

                                    <div class="summary-icon completed-icon">

                                        <svg width="22"
                                             height="22"
                                             viewBox="0 0 24 24"
                                             fill="#0d6efd">

                                            <path d="M9 16.17L4.83 12L3.41 13.41L9 19L21 7Z" />

                                        </svg>

                                    </div>

                                    <div class="summary-count">
                                        @Model.CompletedCount
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div> *@


            </div>

        </div>

        <!-- Quick Actions -->
        <div class="col-12 col-lg-4">

            <div class="dashboard-card h-100">

                <div class="section-title">
                    Quick Actions
                </div>

                <div class="d-grid gap-3">

                    <button class="btn custom-btn-outline">
                        View Schedule
                    </button>

                    <button class="btn custom-btn-outline">
                        Reports
                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- RECENT TASKS -->
    <div class="dashboard-card">

        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">

            <div class="section-title mb-0">
                Recent Tasks
            </div>

            <a asp-controller="AdminService"
               asp-action="Records"
               class="view-all-link">
                View All
            </a>

        </div>

        <!-- MOBILE CARD VIEW -->
        <div class="mobile-task-list d-block d-md-none">

            @if (!Model.RecentServices.Any())
            {
                <div class="text-center text-muted py-4">
                    No service requests
                </div>
            }
            else
            {
                @foreach (var item in Model.RecentServices)
                {
                    <div class="task-mobile-card">

                        <div class="d-flex justify-content-between align-items-start mb-2">

                            <div>
                                <div class="fw-bold">
                                    #AC-@item.ServiceId
                                </div>

                                <div class="small text-muted">
                                    @item.Customer?.Name
                                </div>
                            </div>

                            <span class="badge rounded-pill"
                                  style="@StatusStyle(item?.Status ?? "")">
                                @item.Status
                            </span>

                        </div>

                        <div class="small text-muted mb-1">
                            📍 @item.Customer?.Address
                        </div>

                        <div class="small">
                            📅 @item.CreatedAt.ToString("dd MMM yyyy")
                        </div>

                    </div>
                }
            }

        </div>

        <!-- DESKTOP TABLE -->
        <div class="table-responsive d-none d-md-block">

            <table class="table align-middle table-hover">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>

                <tbody>

                    @if (!Model.RecentServices.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                No service requests
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.RecentServices)
                        {
                            <tr>

                                <td>
                                    #AC-@item.ServiceId
                                </td>

                                <td>
                                    @item.Customer?.Name
                                </td>

                                <td>
                                    @item.Customer?.Address
                                </td>

                                <td>
                                    <span class="badge rounded-pill"
                                          style="@StatusStyle(item.Status)">
                                        @item.Status
                                    </span>
                                </td>

                                <td>
                                    @item.CreatedAt.ToString("dd MMM yyyy")
                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<style>

    /* =========================
           BODY
        ========================== */

    body {
        background: #f4f7fb;
        font-family: 'Segoe UI', sans-serif;
        overflow-x: hidden;
    }

    /* =========================
           CONTAINER
        ========================== */

    .dashboard-container {
        padding: 20px;
    }

    /* =========================
           HEADER
        ========================== */

    .dashboard-header {
        background: #ffffff;
        border-radius: 22px;
        padding: 22px;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .dashboard-title {
        font-size: 30px;
        font-weight: 800;
        margin-bottom: 6px;
        color: #111827;
    }

    .dashboard-subtitle {
        color: #6b7280;
        margin-bottom: 0;
        font-size: 14px;
    }

    .dashboard-date {
        text-align: right;
        color: #6b7280;
        font-size: 14px;
        font-weight: 500;
    }

    /* =========================
           CARD
        ========================== */

    .dashboard-card {
        background: #ffffff;
        border-radius: 22px;
        padding: 20px;
        border: 1px solid #eef2f7;
        box-shadow: 0 4px 20px rgba(0,0,0,0.04);
        transition: all 0.3s ease;
        height: 100%;
    }

        .dashboard-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        }

    /* =========================
           TOP CARD
        ========================== */

    .card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
    }

    .card-label {
        color: #6b7280;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 6px;
    }

    .card-number {
        font-size: 34px;
        font-weight: 800;
        line-height: 1;
        color: #111827;
    }

    .card-text {
        color: #9ca3af;
        font-size: 13px;
        margin-top: 6px;
    }

    /* =========================
           ICON
        ========================== */

    .card-icon {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .assigned-icon {
        background: rgba(13,202,240,0.15);
    }

    .pending-icon {
        background: rgba(255,193,7,0.18);
    }

    .accepted-icon {
        background: rgba(25,135,84,0.15);
    }

    .completed-icon {
        background: rgba(13,110,253,0.15);
    }

    /* =========================
           SECTION TITLE
        ========================== */

    .section-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 18px;
        color: #111827;
    }

    /* =========================
           PROGRESS BAR
        ========================== */

    .custom-progress {
        height: 10px;
        background: #e5e7eb;
        border-radius: 20px;
        overflow: hidden;
    }

    .custom-progress-bar {
        height: 100%;
        border-radius: 20px;
        background: linear-gradient(to right, #0dcaf0, #0d6efd);
    }

    /* =========================
           SUMMARY ITEM
        ========================== */

    .summary-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f9fafb;
        border: 1px solid #eef2f7;
        padding: 15px;
        border-radius: 16px;
        transition: all 0.3s ease;
        min-height: 82px;
    }

        .summary-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.05);
        }

    .summary-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .summary-color {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .assigned-bg {
        background: #0dcaf0;
    }

    .pending-bg {
        background: #ffc107;
    }

    .accepted-bg {
        background: #198754;
    }

    .completed-bg {
        background: #0d6efd;
    }

    .summary-title {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
    }

    .summary-subtitle {
        font-size: 12px;
        color: #6b7280;
        margin-top: 4px;
    }

    .summary-count {
        font-size: 30px;
        font-weight: 800;
        color: #0d6efd;
        min-width: 45px;
        text-align: right;
    }

    /* =========================
           BUTTON
        ========================== */

    .custom-btn-outline {
        border-radius: 14px;
        padding: 12px;
        border: 1px solid #dbe3ec;
        background: #ffffff;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .custom-btn-outline:hover {
            background: #0d6efd;
            color: white;
            border-color: #0d6efd;
        }

    /* =========================
           VIEW ALL
        ========================== */

    .view-all-link {
        color: #0d6efd;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
    }

        .view-all-link:hover {
            text-decoration: underline;
        }

    /* =========================
           TABLE
        ========================== */

    .table {
        margin-bottom: 0;
    }

        .table th {
            font-size: 13px;
            color: #6b7280;
            font-weight: 700;
            border-bottom: 2px solid #e5e7eb;
            padding: 14px 10px;
        }

        .table td {
            font-size: 14px;
            vertical-align: middle;
            padding: 14px 10px;
            border-bottom: 1px solid #f1f5f9;
        }

    /* =========================
           BADGE
        ========================== */

    .badge {
        padding: 7px 12px;
        font-size: 11px;
        font-weight: 600;
        border-radius: 50px;
    }

    /* =========================
           MOBILE TASK CARD
        ========================== */

    .task-mobile-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 16px;
        margin-bottom: 15px;
        border: 1px solid #eef2f7;
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
    }

    /* =========================
           RESPONSIVE
        ========================== */

    @@media(max-width:992px) {

        .dashboard-container {
            padding: 16px;
        }

        .dashboard-title {
            font-size: 27px;
        }

        .card-number {
            font-size: 30px;
        }

        .summary-count {
            font-size: 28px;
        }
    }

    @@media(max-width:768px) {

        .dashboard-container {
            padding: 12px;
        }

        .dashboard-header {
            padding: 18px;
            border-radius: 18px;
        }

        .dashboard-title {
            font-size: 24px;
        }

        .dashboard-subtitle {
            font-size: 13px;
        }

        .dashboard-date {
            text-align: left;
            font-size: 13px;
        }

        .dashboard-card {
            padding: 16px;
            border-radius: 18px;
        }

        .card-number {
            font-size: 28px;
        }

        .card-icon {
            width: 50px;
            height: 50px;
        }

        .section-title {
            font-size: 16px;
        }

        .summary-item {
            padding: 13px;
            min-height: 76px;
        }

        .summary-count {
            font-size: 25px;
        }

        .custom-btn-outline {
            font-size: 14px;
        }

        .table td,
        .table th {
            white-space: nowrap;
        }
    }

    @@media(max-width:576px) {

        .dashboard-title {
            font-size: 22px;
        }

        .dashboard-card {
            padding: 14px;
        }

        .card-number {
            font-size: 24px;
        }

        .card-icon {
            width: 44px;
            height: 44px;
        }

        .summary-item {
            padding: 12px;
        }

        .summary-title {
            font-size: 14px;
        }

        .summary-subtitle {
            font-size: 11px;
        }

        .summary-count {
            font-size: 22px;
        }

        .task-mobile-card {
            padding: 14px;
        }
    }

</style>