@{
    ViewData["Title"] = "QR Code";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
}

<style>
    body {
        background: #f4f8fa;
    }

    .qr-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
    }

    .qr-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,.1);
        padding: 35px;
        text-align: center;
        max-width: 420px;
        width: 100%;
    }

    .qr-title {
        color: #2c8c99;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .qr-subtitle {
        color: #636e72;
        font-size: 14px;
        margin-bottom: 20px;
    }

    .qr-box {
        padding: 15px;
        border: 2px dashed #2c8c99;
        border-radius: 15px;
        display: inline-block;
        margin-bottom: 15px;
        background: #f8fcfc;
    }

        .qr-box img {
            width: 220px;
        }

    .qr-url {
        font-size: 12px;
        color: #888;
        word-break: break-all;
        margin-top: 10px;
    }

    .btn-custom {
        border: none;
        border-radius: 25px;
        padding: 10px 18px;
        font-size: 14px;
        margin: 5px;
        transition: .3s;
    }

    .btn-print {
        background: #2c8c99;
        color: #fff;
    }

        .btn-print:hover {
            background: #226f7a;
            color: #fff;
        }

    .btn-open {
        background: #00b894;
        color: #fff;
    }

        .btn-open:hover {
            background: #00997a;
            color: #fff;
        }

    .success-icon {
        font-size: 40px;
        color: #2c8c99;
        margin-bottom: 10px;
    }
</style>

<div class="qr-wrapper">

    <div class="qr-card">

        <div class="success-icon">✔</div>

        <h3 class="qr-title">Service Completed</h3>

        <p class="qr-subtitle">
            QR Code generated successfully. Scan to open customer dashboard.
        </p>

        <div id="printArea" class="qr-box">
            <img src="@ViewBag.QrImage" />
            <div class="qr-url">@ViewBag.QrUrl</div>
        </div>

        <div class="mt-3">
            <button class="btn-custom btn-print" onclick="window.print()">
                🖨 Print QR
            </button>

            <a href="@ViewBag.QrUrl" class="btn-custom btn-open">
                Open Link
            </a>
        </div>

    </div>

</div>

<style>
    @@media print {
        .btn-custom {
            display: none;
        }

        body {
            background: #fff;
        }

        .qr-card {
            box-shadow: none;
            border: none;
        }
    }
</style>