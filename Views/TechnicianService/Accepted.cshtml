@model IEnumerable<ServiceRequest>
@{
    ViewData["Title"] = "Accepted Jobs";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
}
<h3>Accepted Jobs</h3>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Customer</th>
            <th>Location</th>
            <th>Service Type</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Customer.Name</td>
                <td>@s.Location</td>
                <td>@s.ServiceType</td>
                <td>@s.Status</td>
                <td>
                    <a asp-action="Complete" asp-route-id="@s.ServiceId" class="btn btn-primary btn-sm">Complete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
