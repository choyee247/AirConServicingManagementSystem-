@model List<AirConServicingManagementSystem.Models.Technician>

@{
    ViewData["Title"] = "Availability Technician";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    body {
        background: #f4f8fa;
    }

    .page-title {
        color: #2c8c99;
        font-weight: 700;
        margin-bottom: 25px;
    }

    .availability-card {
        background: #fff;
        border: none;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .card-header-custom {
        background: linear-gradient(135deg,#2c8c99,#45a8b5);
        color: white;
        padding: 20px 30px;
    }

        .card-header-custom h4 {
            margin: 0;
            font-weight: 600;
        }

    .table {
        margin-bottom: 0;
    }

        .table thead {
            background: #eef7f8;
        }

            .table thead th {
                color: #2c8c99;
                font-weight: 600;
                border: none;
                padding: 18px 25px;
                font-size: 15px;
                text-transform: uppercase;
                letter-spacing: .5px;
            }

        .table tbody tr {
            transition: all .3s ease;
        }

            .table tbody tr:hover {
                background: #f8fcfc;
                transform: scale(1.005);
            }

        .table td {
            padding: 20px 25px;
            vertical-align: middle;
            border-top: 1px solid #edf2f4;
            font-size: 15px;
        }

    .tech-name {
        font-weight: 600;
        color: #2d3436;
    }

    .status-badge {
        padding: 10px 18px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 600;
        display: inline-block;
        min-width: 110px;
        text-align: center;
    }

    .available {
        background: rgba(44,140,153,.15);
        color: #2c8c99;
    }

    .busy {
        background: #ffe5e5;
        color: #d63031;
    }

    .status-dot {
        height: 10px;
        width: 10px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }

    .dot-available {
        background: #2c8c99;
    }

    .dot-busy {
        background: #d63031;
    }

    .summary-box {
        background: white;
        border-radius: 18px;
        padding: 20px;
        box-shadow: 0 6px 18px rgba(0,0,0,.05);
        margin-bottom: 20px;
    }

    .summary-number {
        font-size: 30px;
        font-weight: 700;
        color: #2c8c99;
    }
</style>

<div class="container py-4">

    <h2 class="page-title">
        Technician Availability 
    </h2>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="summary-box">
                <small>Total Technicians</small>
                <div class="summary-number">
                    @Model.Count
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="summary-box">
                <small>Available</small>
                <div class="summary-number">
                    @Model.Count(x => x.IsAvailable)
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="summary-box">
                <small>Busy</small>
                <div class="summary-number">
                    @Model.Count(x => !x.IsAvailable)
                </div>
            </div>
        </div>
    </div>

    <div class="availability-card">
        <div class="card-header-custom">
            <h4>Technician Status</h4>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>Technician</th>
                    <th>Status</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="tech-name">
                            @item.Name
                        </td>

                        <td>
                            @if (item.IsAvailable)
                            {
                                <span class="status-badge available">
                                    <span class="status-dot dot-available"></span>
                                    Available
                                </span>
                            }
                            else
                            {
                                <span class="status-badge busy">
                                    <span class="status-dot dot-busy"></span>
                                    Busy
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>