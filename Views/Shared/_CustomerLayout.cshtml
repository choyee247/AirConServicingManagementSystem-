@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AirConServ</title>

    <!-- Bootstrap 5 -->
    <link href="~/bootstrap/bootstrap.min530.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="~/fontawesome/css/all.min640.css" rel="stylesheet" />

    <style>
        :root {
            --primary: #2c8c99;
            --sidebar-width: 250px;
            --sidebar-collapsed: 70px;
            --header-height: 60px;
        }

        body {
            margin: 0;
            display: flex;
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            background: #f4f6f9;
        }

        /* ===== Sidebar ===== */
        .sidebar {
            width: var(--sidebar-width);
            background: linear-gradient(180deg, var(--primary), #23727d);
            color: #fff;
            position: fixed;
            height: 100vh;
            transition: .3s;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

            .sidebar.collapsed {
                width: var(--sidebar-collapsed);
            }

        .sidebar-header {
            height: var(--header-height);
            padding: 0 15px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid rgba(255,255,255,.15);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: 1.2rem;
        }

        .sidebar.collapsed .logo span {
            display: none;
        }

        .toggle-btn {
            background: rgba(255,255,255,.15);
            border: none;
            color: #fff;
            width: 32px;
            height: 32px;
            border-radius: 6px;
        }

        .nav-menu {
            list-style: none;
            padding: 15px 0;
            margin: 0;
            flex: 1;
            overflow-y: auto;
        }

            .nav-menu::-webkit-scrollbar {
                width: 5px;
            }

            .nav-menu::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,.3);
                border-radius: 10px;
            }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px;
            color: rgba(255,255,255,.9);
            text-decoration: none;
            transition: .2s;
        }

            .nav-link:hover,
            .nav-link.active {
                background: rgba(255,255,255,.15);
                color: #fff;
            }

        .sidebar.collapsed .nav-text {
            display: none;
        }

        .sidebar-footer {
            margin-top: auto; /* pushes to bottom naturally */
            padding: 15px;
            border-top: 1px solid rgba(255,255,255,.15);
        }

        /* ===== Main ===== */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            display: flex;
            flex-direction: column;
            transition: .3s;
        }

        .sidebar.collapsed ~ .main-content {
            margin-left: var(--sidebar-collapsed);
        }

        .top-header {
            height: var(--header-height);
            background: #fff;
            border-bottom: 1px solid #ddd;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .content-wrapper {
            padding: 20px;
            flex: 1;
        }

        .content-card {
            background: #fff;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 2px 10px rgba(0,0,0,.05);
        }

        footer {
            background: #fff;
            border-top: 1px solid #ddd;
            text-align: center;
            padding: 12px;
            font-size: .9rem;
            color: #777;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ===== Sidebar ===== -->
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <i class="fas fa-fan"></i>
                <span>Customer AirCon Service</span>
            </div>
            <button class="toggle-btn" id="sidebarToggle">
                <i class="fas fa-bars"></i>
            </button>
        </div>

        <div class="nav-menu">

        <!-- UPDATED CUSTOMER SIDEBAR (FLOW-BASED) -->
            <ul class="p-0 m-0">

            <!-- Dashboard -->
            <li>
                <a class="nav-link active" href="/CustomerDashboard/Index">
                    <i class="fas fa-home"></i>
                    <span class="nav-text">Dashboard</span>
                </a>
            </li>

            <!-- STEP 1: My AirCon (QR + Units) -->
            <li>
                <a class="nav-link" href="/CustomerDashboard/Aircons">
                    <i class="fas fa-snowflake"></i>
                    <span class="nav-text">My AirCon Units</span>
                </a>
            </li>

            <!-- STEP 2: Request Service -->
            <li>
                <a class="nav-link" href="/ServiceRequest/Create">
                    <i class="fas fa-plus-circle"></i>
                    <span class="nav-text">Request Service</span>
                </a>
            </li>

            <!-- STEP 3: My Requests (Tracking) -->
            <li>
                <a class="nav-link" href="/ServiceRequest/MyRequests">
                    <i class="fas fa-tasks"></i>
                    <span class="nav-text">My Requests</span>
                </a>
            </li>

            <!-- STEP 4: Appointments -->
            <li>
                <a class="nav-link" href="/CustomerAppointment/Index">
                    <i class="fas fa-calendar-check"></i>
                    <span class="nav-text">Appointments</span>
                </a>
            </li>

            <!-- STEP 5: Service History -->
            <li>
                <a class="nav-link" href="/ServiceRequest/History">
                    <i class="fas fa-history"></i>
                    <span class="nav-text">Service History</span>
                </a>
            </li>

            <!-- STEP 6: Payments -->
            <li>
                <a class="nav-link" href="/CustomerPayment/Index">
                    <i class="fas fa-money-bill-wave"></i>
                    <span class="nav-text">Payments</span>
                </a>
            </li>

            <!-- STEP 7: Warranty -->
            <li>
                <a class="nav-link" href="/ServiceRequest/Warranty">
                    <i class="fas fa-shield-alt"></i>
                    <span class="nav-text">Warranty</span>
                </a>
            </li>

            <!-- Notifications -->
            <li>
                <a class="nav-link" href="/CustomerNotification/Index">
                    <i class="fas fa-bell"></i>
                    <span class="nav-text">Notifications</span>
                </a>
            </li>

            <!-- Profile -->
            <li>
                <a class="nav-link" href="/CustomerDashboard/Profile">
                    <i class="fas fa-user"></i>
                    <span class="nav-text">My Profile</span>
                </a>
            </li>

        </ul>

        <!-- IMPROVED HEADER INFO -->
       @*  <div class="alert alert-info mt-4">
            <i class="fas fa-info-circle"></i>
            <strong>How it works:</strong><br>
            1. Select your AirCon Unit → 2. Request Service → 3. Track Request → 4. Appointment → 5. Service Done → 6. Payment
        </div>
        </div> *@

        <div class="sidebar-footer">
            @if (HttpContextAccessor.HttpContext.Session.GetInt32("CustomerId") != null)
            {
                <div>
                    <i class="fas fa-user"></i>
                    <strong>@HttpContextAccessor.HttpContext.Session.GetString("CustomerName")</strong><br />
                    <small>Customer</small>
                </div>
            }
        </div>
    </nav>

    <!-- ===== Main Content ===== -->
    <div class="main-content">
        <header class="top-header">
            <h5 class="m-0">@ViewData["Title"]</h5>

            <div class="d-flex align-items-center gap-3">
                <small class="text-muted">@DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")</small>

                <a asp-controller="CustomerLogin" asp-action="Logout" class="text-danger text-decoration-none">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </header>

        <main class="content-wrapper">
            <div class="content-card">
                @RenderBody()

                <!-- Payment Info -->
                <div class="alert alert-info mt-4">
                    <i class="fas fa-money-bill-wave"></i>
                    <strong>Payment:</strong> Cash – Pay directly to technician after service completion.
                </div>
            </div>
        </main>

        <footer>
            &copy; @DateTime.Now.Year AirConServ. All rights reserved.
        </footer>
    </div>

    <script src="~/bootstrap/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById("sidebarToggle")
            .addEventListener("click", () =>
                document.getElementById("sidebar").classList.toggle("collapsed"));
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
