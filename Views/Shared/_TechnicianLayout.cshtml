@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Technician Panel</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/fontawesome/css/all.min640.css" />

    <style>
        :root {
            --primary: #2c8c99;
            --dark: #23727d;
            --sidebar-width: 260px;
            --sidebar-collapsed: 70px;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI';
            background: #f5f7fa;
        }

        .app {
            display: flex;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: var(--sidebar-width);
            background: linear-gradient(180deg, var(--primary), var(--dark));
            color: #fff;
            height: 100vh;
            position: fixed;
            transition: 0.3s;
            overflow-y: auto;
        }

            .sidebar.collapsed {
                width: var(--sidebar-collapsed);
            }

        .sidebar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            border-bottom: 1px solid rgba(255,255,255,.2);
        }

        .logo span {
            font-weight: bold;
        }

        .sidebar.collapsed .logo span {
            display: none;
        }

        .toggle-btn {
            border: none;
            background: rgba(255,255,255,.2);
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 6px;
        }

        .nav-menu {
            list-style: none;
            padding: 10px;
        }

        .nav-link {
            display: flex;
            gap: 10px;
            padding: 12px;
            color: rgba(255,255,255,.9);
            text-decoration: none;
            border-radius: 8px;
            transition: .2s;
        }

            .nav-link:hover,
            .nav-link.active {
                background: rgba(255,255,255,.2);
                color: white;
            }

        .sidebar.collapsed .nav-text {
            display: none;
        }

        /* ===== MAIN ===== */
        .main {
            margin-left: var(--sidebar-width);
            width: 100%;
            transition: 0.3s;
        }

        .sidebar.collapsed ~ .main {
            margin-left: var(--sidebar-collapsed);
        }

        .header {
            background: #fff;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            border-bottom: 1px solid #ddd;
        }

        .content {
            padding: 20px;
        }

        .card-box {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 10px rgba(0,0,0,.05);
        }

        footer {
            text-align: center;
            padding: 10px;
            color: #777;
        }

    </style>
</head>

<body>
    <div class="app">

        <!-- ===== SIDEBAR ===== -->
        <nav class="sidebar" id="sidebar">

            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-tools"></i>
                    <span>Technician</span>
                </div>

                <button id="toggleBtn" class="toggle-btn">
                    <i class="fas fa-bars"></i>
                </button>
            </div>

            <!-- FLOW INFO -->
            @* <div class="p-2">
                <small>
                    <b>Flow:</b><br>
                    Assign → Accept → Appointment → Service → Complete → Payment
                </small>
            </div> *@

            <!-- MENU -->
            <ul class="nav-menu">

                <li>
                    <a href="/TechnicianService/Dashboard" class="nav-link">
                        <i class="fas fa-home"></i>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </li>

                <li>
                    <a href="/TechnicianService/Assigned" class="nav-link">
                        <i class="fas fa-clipboard-list"></i>
                        <span class="nav-text">Assigned Jobs</span>
                    </a>
                </li>

                <li>
                    <a href="/TechnicianService/Accepted" class="nav-link">
                        <i class="fas fa-check-circle"></i>
                        <span class="nav-text">Accept / Cancel</span>
                    </a>
                </li>

                <li>
                    <a href="/CustomerAppointment/Index" class="nav-link">
                        <i class="fas fa-calendar-check"></i>
                        <span class="nav-text">Appointments</span>
                    </a>
                </li>

                <li>
                    <a href="/ServiceJobs/OnSite" class="nav-link">
                        <i class="fas fa-map-marker-alt"></i>
                        <span class="nav-text">On-Site Service</span>
                    </a>
                </li>

                <li>
                    <a href="/TechnicianService/UpdateStatus" class="nav-link">
                        <i class="fas fa-tasks"></i>
                        <span class="nav-text">Update Status</span>
                    </a>
                </li>

                <li>
                    <a href="/Payments/CashCollection" class="nav-link">
                        <i class="fas fa-money-bill-wave"></i>
                        <span class="nav-text">Cash Collection</span>
                    </a>
                </li>

                <hr />

                <a href="/TechnicianService/GenerateQR?customerId=1" class="nav-link">
                    <i class="fas fa-qrcode"></i>
                    <span class="nav-text">Generate QR</span>
                </a>

                <li>
                    <a href="/Technician/Profile" class="nav-link">
                        <i class="fas fa-user"></i>
                        <span class="nav-text">Profile</span>
                    </a>
                </li>

            </ul>

            <!-- USER -->
            <div class="p-3 border-top">
                <b>@HttpContextAccessor.HttpContext.Session.GetString("TechnicianName")</b><br />
                <small>Technician</small>
            </div>

        </nav>


        <!-- ===== MAIN ===== -->
        <div class="main">

            <div class="header">
                <h5>@ViewData["Title"]</h5>

                <div>
                    @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
                    |
                    <a asp-controller="TechnicianAuth" asp-action="Logout" class="text-danger">
                        Logout
                    </a>
                </div>
            </div>

            <div class="content">
                <div class="card-box">
                    @RenderBody()
                </div>
            </div>

            <footer>
                © @DateTime.Now.Year AirCon System
            </footer>

        </div>

    </div>

    <script>
        // Sidebar toggle
        document.getElementById("toggleBtn").onclick = () => {
            document.getElementById("sidebar").classList.toggle("collapsed");
        };

        // Active menu fix
        const path = window.location.pathname.toLowerCase();
        document.querySelectorAll(".nav-link").forEach(link => {
            if (path.includes(link.getAttribute("href").toLowerCase())) {
                link.classList.add("active");
            }
        });
    </script>

    @RenderSection("Scripts", false)

</body>
</html>