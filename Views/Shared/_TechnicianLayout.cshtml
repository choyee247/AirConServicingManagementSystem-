@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Technician Panel</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/fontawesome/css/all.min640.css" />

    <style>

        :root {
            --primary: #2c8c99;
            --dark: #1f6b75;
            --sidebar-width: 260px;
            --sidebar-collapsed: 75px;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI';
            background: #f4f7fb;
            overflow-x: hidden;
        }

        /* ================= SIDEBAR ================= */

        .sidebar {
            width: var(--sidebar-width);
            background: linear-gradient(180deg, var(--primary), var(--dark));
            color: white;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            transition: .3s;
            overflow-y: auto;
            z-index: 1000;
        }

            .sidebar.collapsed {
                width: var(--sidebar-collapsed);
            }

        /* HEADER */
        .sidebar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px;
            border-bottom: 1px solid rgba(255,255,255,.15);
        }

        .logo {
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar.collapsed .logo span {
            display: none;
        }

        .toggle-btn {
            background: rgba(255,255,255,.15);
            border: none;
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 6px;
        }

        /* MENU */
        .nav-menu {
            list-style: none;
            padding: 10px;
            margin: 0;
        }

        .nav-link,
        .submenu-toggle {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            color: rgba(255,255,255,.92);
            text-decoration: none;
            border-radius: 10px;
            transition: .25s;
            cursor: pointer;
        }

            .nav-link:hover,
            .nav-link.active,
            .submenu-toggle:hover {
                background: rgba(255,255,255,.18);
                color: #fff;
            }

        .sidebar.collapsed .nav-text,
        .sidebar.collapsed .link-text {
            display: none;
        }

        /* SUBMENU */
        .has-submenu .submenu {
            display: none;
            padding-left: 12px;
            margin-top: 5px;
        }

        .has-submenu.open .submenu {
            display: block;
        }

        .submenu li {
            list-style: none;
        }

        .submenu a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            margin-bottom: 5px;
            border-radius: 8px;
            text-decoration: none;
            color: rgba(255,255,255,.85);
            transition: .25s;
        }

            .submenu a:hover {
                background: rgba(255,255,255,.12);
                color: #fff;
            }

        .submenu-icon {
            margin-left: auto;
            transition: .3s;
        }

        .has-submenu.open .submenu-icon {
            transform: rotate(180deg);
        }

        /* ================= MAIN ================= */

        .app {
            display: flex;
        }

        .main {
            flex: 1;
            margin-left: var(--sidebar-width);
            transition: .3s;
            min-width: 0;
            overflow-x: hidden;
        }

        .sidebar.collapsed ~ .main {
            margin-left: var(--sidebar-collapsed);
        }

        /* HEADER */
        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 18px;
            background: #fff;
            border-bottom: 1px solid #eee;
            flex-wrap: wrap;
            gap: 10px;
        }

            .header h5 {
                margin: 0;
                font-weight: 700;
            }
        /* CONTENT */
        .content {
            padding: 20px;
        }

        .card-box {
            background: #fff;
            padding: 22px;
            border-radius: 16px;
            box-shadow: 0 6px 20px rgba(0,0,0,.05);
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-left: auto;
        }
        .footer {
            background: #fff;
            border-top: 1px solid #eee;
            text-align: center;
            padding: 10px;
            position: sticky;
            bottom: 0;
        }


        /* ================= USER FOOTER ================= */

        .sidebar-user {
            position: absolute;
            bottom: 0;
            width: 100%;
            padding: 15px;
            border-top: 1px solid rgba(255,255,255,.15);
            background: rgba(0,0,0,.15);
        }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #2c8c99;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        .user-box {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        /* ================= MOBILE ================= */

        .mobile-toggle {
            display: none;
            background: var(--primary);
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 8px;
        }

        .sidebar-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.5);
            z-index: 999;
        }

        @@media (max-width: 991px) {

            .sidebar {
                left: -260px;
            }

                .sidebar.open {
                    left: 0;
                }

            .main {
                margin-left: 0 !important;
            }

            .mobile-toggle {
                display: inline-block;
            }

            .sidebar-backdrop.show {
                display: block;
            }
        }

    </style>
    @RenderSection("Styles", required: false)

</head>

<body>

    <div class="sidebar-backdrop" id="backdrop"></div>

    <div class="sidebar" id="sidebar">

        <!-- HEADER -->
        <div class="sidebar-header">
            <div class="logo">
                <i class="fas fa-tools"></i>
                <span>Technician</span>
            </div>

            <button class="toggle-btn" id="toggleBtn">
                <i class="fas fa-bars"></i>
            </button>
        </div>

        <!-- MENU -->
        <ul class="nav-menu">

            <li>
                <a href="/TechnicianService/Dashboard" class="nav-link">
                    <i class="fas fa-home"></i>
                    <span class="nav-text">Dashboard</span>
                </a>
            </li>

            <!-- CUSTOMER & UNITS -->
            <li class="has-submenu">

                <a class="submenu-toggle">
                    <i class="fa-solid fa-user-plus"></i>
                    <span class="link-text">Customer & Units</span>
                    <i class="fa-solid fa-chevron-down submenu-icon"></i>
                </a>

                <ul class="submenu">

                    <li>
                        <a asp-controller="Customer" asp-action="Index">
                            <i class="fa-solid fa-users"></i>
                            <span class="link-text"> Customers</span>
                        </a>
                    </li>
                   
                    <li>
                        <a asp-controller="Customer" asp-action="Create">
                            <i class="fa-solid fa-user-plus"></i>
                            <span class="link-text">Add Customer</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="AirConBrand" asp-action="Brands">
                            <i class="fa-solid fa-tags"></i>
                            <span class="link-text">Brands</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="AirConModel" asp-action="Models">
                            <i class="fa-solid fa-cubes"></i>
                            <span class="link-text"> Models</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="AirConUnit" asp-action="Index">
                            <i class="fa-solid fa-wind"></i>
                            <span class="link-text">Units</span>
                        </a>
                    </li>

                </ul>
            </li>
            <li>
                <a href="/Appointment/Index" class="nav-link">
                    <i class="fas fa-calendar-check"></i>
                    <span class="nav-text">Appointments</span>
                </a>
            </li>
            <li>
                <a href="/TechnicianService/Assigned" class="nav-link">
                    <i class="fas fa-clipboard-list"></i>
                    <span class="nav-text">Assigned Jobs</span>
                </a>
            </li>

           @*  <li>
                <a href="/TechnicianService/Accepted" class="nav-link">
                    <i class="fas fa-check-circle"></i>
                    <span class="nav-text">Accept / Cancel</span>
                </a>
            </li> *@
            <li class="has-submenu">

                <a class="submenu-toggle">
                    <i class="fa-solid fa-screwdriver-wrench"></i>
                    <span class="link-text">Service</span>
                    <i class="fa-solid fa-chevron-down submenu-icon"></i>
                </a>

                <ul class="submenu">

                    <li>
                        <a asp-controller="ServiceRequest" asp-action="Index">
                            <i class="fa-solid fa-list"></i>
                            <span class="link-text">My Service</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="AdminService" asp-action="Records">
                            <i class="fa-solid fa-file-lines"></i>
                            <span class="link-text">Service Records</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="AdminMaintenance" asp-action="Index">
                            <i class="fa-solid fa-calendar-check"></i>
                            <span class="link-text">Maintenance</span>
                        </a>
                    </li>

                    <li>
                        <a asp-controller="ServiceFee" asp-action="Index">
                            <i class="fa-solid fa-money-bill-wave"></i>
                            <span class="link-text">Service Fees</span>
                        </a>
                    </li>

                </ul>
            </li>
          

            @* <li>
                <a href="/Payments/CashCollection" class="nav-link">
                    <i class="fas fa-money-bill"></i>
                    <span class="nav-text">Payments</span>
                </a>
            </li> *@
            <li>
                <a href="/Feedback/Index" class="nav-link">
                    <i class="fa-solid fa-star"></i>
                    <span class="nav-text">Feedback</span>
                </a>
            </li>
            <li>
                <a href="/Schedule/Index" class="nav-link">
                    <i class="fa-solid fa-calendar-days"></i>
                    <span class="nav-text">My Schedule</span>
                </a>
            </li>
            <li>
                <a href="/Reminder/Index" class="nav-link">
                    <i class="fa-solid fa-bell"></i>
                    <span class="nav-text">Reminders</span>
                </a>
            </li>
            <li>
                <a href="/TechnicianProfile/Index" class="nav-link">
                    <i class="fa-solid fa-user-gear"></i>
                    <span class="nav-text">My Profile</span>
                </a>
            </li>
           
        </ul>

        <!-- USER -->
        @* <div class="sidebar-user">
            <div class="d-flex align-items-center gap-2">
                <div class="avatar">
                    @(HttpContextAccessor.HttpContext.Session.GetString("TechnicianName")?.Substring(0, 1))
                </div>

                <div>
                    <div class="fw-bold text-white">
                        @HttpContextAccessor.HttpContext.Session.GetString("TechnicianName")
                    </div>
                    <small class="text-white-50">Technician</small>
                </div>
            </div>
        </div> *@

    </div>

    <!-- MAIN -->
   <div class="main">

    <!-- HEADER -->
        <div class="header">

            <button class="mobile-toggle" id="mobileToggle">
                <i class="fas fa-bars"></i>
            </button>

            <h5 class="mb-0 page-title">@ViewData["Title"]</h5>

            <div class="header-right">

                <!-- DATE -->
                <div class="text-muted small d-none d-md-block">
                    @DateTime.Now.ToString("dd MMM yyyy hh:mm tt")
                </div>

                <!-- USER -->
                <div class="user-box">

                    <div class="avatar">
                        @(HttpContextAccessor.HttpContext.Session.GetString("TechnicianName")?.Substring(0, 1))
                    </div>

                    <div class="user-info">
                        <div class="fw-bold">
                            @HttpContextAccessor.HttpContext.Session.GetString("TechnicianName")
                        </div>
                        <small class="text-muted">Technician</small>
                    </div>

                </div>

                <!-- LOGOUT -->
                <a asp-controller="TechnicianAuth"
                   asp-action="Logout"
                   class="btn btn-sm btn-outline-danger">
                    Logout
                </a>

            </div>

        </div>

        <!-- CONTENT -->
        <div class="content">
            <div class="card-box">
                @RenderBody()
            </div>
        </div>

        <!-- FOOTER -->
        <footer class="footer">
            © @DateTime.Now.Year AirCon System
        </footer>

    </div>

    <script>

        document.querySelectorAll('.submenu-toggle').forEach(menu => {
            menu.addEventListener('click', function () {
                this.closest('.has-submenu').classList.toggle('open');
            });
        });

        const sidebar = document.getElementById("sidebar");
        const backdrop = document.getElementById("backdrop");

        document.getElementById("toggleBtn").onclick = () => {
            sidebar.classList.toggle("collapsed");
        };

        document.getElementById("mobileToggle").onclick = () => {
            sidebar.classList.add("open");
            backdrop.classList.add("show");
        };

        backdrop.onclick = () => {
            sidebar.classList.remove("open");
            backdrop.classList.remove("show");
        };

    </script>

    @RenderSection("Scripts", required: false)
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</body>
</html>