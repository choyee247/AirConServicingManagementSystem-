@model AirConServicingManagementSystem.Models.ServiceRequest
@{
    ViewData["Title"] = "Start Service";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";

    var appt = ViewBag.Appointment as AirConServicingManagementSystem.Models.Appointment;
}

<div class="container py-4">

    <div class="card shadow-sm rounded-3">

        <div class="card-header bg-white">
            <h3 style="color:#2c8c99;font-weight:700;">
                🚀 Start Service
            </h3>
            <p class="text-muted mb-0">
                Confirm service details before starting work
            </p>
        </div>

        <div class="card-body">

            <!-- READONLY APPOINTMENT INFO -->
            <div class="p-3 border rounded mb-4">

                <h5 style="color:#2c8c99;">Appointment Info</h5>

                <p><b>Customer:</b> @appt?.Customer?.Name</p>
                <p><b>Technician:</b> @appt?.Technician?.Name</p>
                <p><b>Location:</b> @appt?.Location</p>
                <p><b>Status:</b> @appt?.Status</p>

            </div>

            <form asp-action="Create" method="post">

                <input type="hidden" name="appointmentId" value="@appt?.AppointmentId" />

                <!-- HIDDEN AUTO VALUES -->
                <input type="hidden" asp-for="CustomerId" />
                <input type="hidden" asp-for="TechnicianId" />

                <!-- SERVICE TYPE -->
                <div class="mb-3">
                    <label>Service Type</label>
                    <select asp-for="ServiceType" class="form-select">
                        <option>Normal</option>
                        <option>Urgent</option>
                    </select>
                </div>

                @* <!-- LOCATION (READONLY) --> *@
                <div class="mb-3">
                    <label>Location</label>
                    <input asp-for="Location" class="form-control" readonly />
                </div>

                <!-- NOTES -->
                <div class="mb-3">
                    <label>Notes</label>
                    <input asp-for="Notes" class="form-control" readonly>
                </div>

                <button type="submit"
                        class="btn w-100 text-white"
                        style="background:#2c8c99;">
                    Start Service
                </button>

            </form>

        </div>

    </div>

</div>