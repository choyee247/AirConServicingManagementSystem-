@model AirConServicingManagementSystem.Models.Customer

@{
    ViewData["Title"] = "Customer Details";
    Layout = "~/Views/Shared/_TechnicianLayout.cshtml";
}

@{
    var airconCount = Model.AirConUnits?.Count ?? 0;

    var allServiceRecords = Model.AirConUnits?
        .Where(a => a.ServiceRecords != null)
        .SelectMany(a => a.ServiceRecords)
        .OrderByDescending(s => s.ServiceDate)
        .ToList() ?? new List<ServiceRecord>();

    var serviceCount = allServiceRecords.Count;
    var completedCount = allServiceRecords.Count(s => s.Status == "Completed");

    var nextServices = allServiceRecords
        .Where(s => s.NextServiceDue != null && s.NextServiceDue >= DateTime.Today)
        .OrderBy(s => s.NextServiceDue)
        .ToList();
}

<div class="customer-details-container">

    <!-- HEADER -->
    <div class="details-header">
        <div class="header-icon">
            <i class="fas fa-user"></i>
        </div>

        <div class="header-content">
            <h1 class="details-title">@Model.Name</h1>
            <p class="details-subtitle">
                Complete customer information, aircon units, warranty and service history
            </p>
        </div>

        <div class="header-actions">
            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn-edit">
                <i class="fas fa-edit"></i> Edit
            </a>
        </div>
    </div>

    <!-- CUSTOMER PROFILE -->
    <div class="details-card">
        <div class="customer-profile">
            <div class="profile-avatar">
                @(string.IsNullOrEmpty(Model.Name)
                    ? "C"
                    : Model.Name.Substring(0, 1).ToUpper())
            </div>

            <div class="profile-info">
                <h2 class="customer-name">@Model.Name</h2>

                <div class="customer-contact">
                    @if (!string.IsNullOrWhiteSpace(Model.Phone))
                    {
                        <span class="contact-item">
                            <i class="fas fa-phone-alt"></i> @Model.Phone
                        </span>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Address))
                    {
                        <span class="contact-item">
                            <i class="fas fa-map-marker-alt"></i> @Model.Address
                        </span>
                    }
                </div>
            </div>
        </div>

        <!-- SUMMARY -->
        <div class="details-grid">
            <!-- Account -->
            <div class="detail-section">
                <h3 class="section-title">
                    <i class="fas fa-info-circle"></i>
                    Account Information
                </h3>

                <div class="detail-item">
                    <div class="detail-label">Customer ID</div>
                    <div class="detail-value">#@Model.Id</div>
                </div>

                <div class="detail-item">
                    <div class="detail-label">Created At</div>
                    <div class="detail-value">
                        @(Model.CreatedAt?.ToString("dd MMM yyyy hh:mm tt") ?? "N/A")
                    </div>
                </div>

                @if (Model.UpdatedAt != null)
                {
                    <div class="detail-item">
                        <div class="detail-label">Updated At</div>
                        <div class="detail-value">
                            @Model.UpdatedAt.Value.ToString("dd MMM yyyy hh:mm tt")
                        </div>
                    </div>
                }
            </div>

            <!-- Statistics -->
            <div class="detail-section">
                <h3 class="section-title">
                    <i class="fas fa-chart-bar"></i>
                    Statistics
                </h3>

                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-value">@airconCount</div>
                        <div class="stat-label">AirCon Units</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-value">@serviceCount</div>
                        <div class="stat-label">Services</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-value">@completedCount</div>
                        <div class="stat-label">Completed</div>
                    </div>
                </div>
            </div>

            <!-- Upcoming Services -->
            <div class="detail-section">
                <h3 class="section-title">
                    <i class="fas fa-calendar-alt"></i>
                    Upcoming Services
                </h3>

                @if (nextServices.Any())
                {
                    foreach (var item in nextServices.Take(5))
                    {
                        <div class="detail-item">
                            <div class="detail-label">
                                @item.NextServiceDue?.ToString("dd MMM yyyy")
                            </div>
                            <div class="detail-value">
                                @item.AirConUnit?.Brand?.BrandName
                                @item.AirConUnit?.Model?.ModelName
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">No upcoming services.</p>
                }
            </div>
        </div>
    </div>

    <!-- AIRCON UNITS -->
    <div class="details-card mt-4">
        <h3 class="section-title mb-4">
            <i class="fas fa-snowflake"></i>
            Air Conditioning Units
        </h3>

        @if (Model.AirConUnits != null && Model.AirConUnits.Any())
        {
            foreach (var aircon in Model.AirConUnits)
            {
                var services = aircon.ServiceRecords?
                .OrderByDescending(s => s.ServiceDate)
                .ToList() ?? new List<ServiceRecord>();

                <div class="aircon-card">

                    <!-- AIRCON HEADER -->
                    <div class="aircon-header">
                        <div>
                            <h4 class="aircon-title">
                                @(aircon.Brand?.BrandName ?? "")
                                @(aircon.Model?.ModelName ?? "")
                            </h4>

                            <p class="aircon-subtitle">
                                @(aircon.AirConType ?? "N/A")
                                •
                                @(aircon.CapacityHp?.ToString() ?? "N/A") HP
                            </p>
                        </div>

                        <span class="badge-custom">
                            @(aircon.NextServiceOption.HasValue
                                ? $"{aircon.NextServiceOption} Month(s)"
                                : "N/A")
                        </span>
                    </div>

                    <!-- AIRCON INFO -->
                    <div class="info-grid">

                        <div class="info-row">
                            <strong>Installation Date:</strong>
                            <span>
                                @(aircon.InstallationDate?.ToString("dd MMM yyyy") ?? "N/A")
                            </span>
                        </div>

                        <div class="info-row">
                            <strong>Warranty:</strong>

                            @if (aircon.Warranty != null)
                            {
                                if (aircon.Warranty.EndDate >= DateTime.Now)
                                {
                                    <span class="text-success fw-bold">
                                        Active until
                                        @aircon.Warranty.EndDate.ToString("dd MMM yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-danger fw-bold">
                                        Expired on
                                        @aircon.Warranty.EndDate.ToString("dd MMM yyyy")
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No Warranty</span>
                            }
                        </div>

                    </div>

                    <!-- SERVICE HISTORY -->
                    <div class="service-section mt-4">
                        <h5 class="service-title">
                            <i class="fas fa-tools"></i>
                            Service History
                        </h5>

                        @if (services.Any())
                        {
                            <div class="table-responsive">
                                <table class="table service-table align-middle">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Service Type</th>
                                            <th>Technician</th>
                                            <th>Status</th>
                                            <th>Next Service</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var service in services)
                                        {
                                            <tr>
                                                <td>
                                                    @(service.ServiceDate?.ToString("dd MMM yyyy") ?? "N/A")
                                                </td>

                                                <td>
                                                    @(service.ServiceType ?? "N/A")
                                                </td>

                                                <td>
                                                    @(service.Technician?.Name ?? "Not Assigned")
                                                </td>

                                                <td>
                                                    <span class="status-badge">
                                                        @(service.Status ?? "N/A")
                                                    </span>
                                                </td>

                                                <td>
                                                    @(service.NextServiceDue?.ToString("dd MMM yyyy") ?? "N/A")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">
                                No service history available.
                            </p>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted mb-0">
                No AirCon units found for this customer.
            </p>
        }
    </div>

    <!-- ALL SERVICE HISTORY -->
    <div class="details-card mt-4">
        <h3 class="section-title mb-4">
            <i class="fas fa-history"></i>
            Complete Service Timeline
        </h3>

        @if (allServiceRecords.Any())
        {
            <div class="table-responsive">
                <table class="table service-table align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>AirCon</th>
                            <th>Service Type</th>
                            <th>Technician</th>
                            <th>Status</th>
                            <th>Next Service</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in allServiceRecords)
                        {
                            <tr>
                                <td>
                                    @(record.ServiceDate?.ToString("dd MMM yyyy") ?? "N/A")
                                </td>

                                <td>
                                    @record.AirConUnit?.Brand?.BrandName
                                    @record.AirConUnit?.Model?.ModelName
                                </td>

                                <td>@(record.ServiceType ?? "N/A")</td>

                                <td>
                                    @(record.Technician?.Name ?? "Not Assigned")
                                </td>

                                <td>
                                    <span class="status-badge">
                                        @(record.Status ?? "N/A")
                                    </span>
                                </td>

                                <td>
                                    @(record.NextServiceDue?.ToString("dd MMM yyyy") ?? "N/A")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No service records found.</p>
        }
    </div>

    <!-- FOOTER -->
    <div class="action-buttons">
        <a asp-action="Index" class="btn-back">
            <i class="fas fa-arrow-left"></i>
            Back to Customers
        </a>
    </div>
</div>

<style>
    :root {
        --primary: #2c8c99;
        --primary-dark: #23727d;
        --primary-light: #eaf7f8;
        --border: #d9ecef;
        --text: #333;
        --text-light: #666;
        --bg: #f8fbfc;
    }

    .customer-details-container {
        max-width: 1300px;
        margin: auto;
    }

    .details-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 25px;
    }

    .header-icon {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 24px;
    }

    .header-content {
        flex: 1;
    }

    .details-title {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary);
    }

    .details-subtitle {
        margin: 4px 0 0;
        color: var(--text-light);
    }

    .details-card {
        background: white;
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 8px 25px rgba(44, 140, 153, 0.08);
    }

    .customer-profile {
        display: flex;
        gap: 20px;
        align-items: center;
        margin-bottom: 30px;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2rem;
        font-weight: bold;
    }

    .customer-name {
        margin: 0;
        font-size: 1.8rem;
        font-weight: 700;
    }

    .customer-contact {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-top: 8px;
    }

    .contact-item {
        color: var(--text-light);
    }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 20px;
    }

    .detail-section {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 20px;
    }

    .section-title {
        color: var(--primary);
        font-weight: 700;
        margin-bottom: 15px;
    }

    .detail-item {
        margin-bottom: 12px;
    }

    .detail-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-light);
        text-transform: uppercase;
    }

    .detail-value {
        font-size: 15px;
        color: var(--text);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .stat-card {
        background: white;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 15px;
        text-align: center;
    }

    .stat-value {
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--primary);
    }

    .stat-label {
        font-size: 12px;
        color: var(--text-light);
    }

    .aircon-card {
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 25px;
        background: #fff;
    }

    .aircon-header {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 15px;
    }

    .aircon-title {
        margin: 0;
        font-weight: 700;
        color: var(--primary);
    }

    .aircon-subtitle {
        margin: 5px 0 0;
        color: var(--text-light);
    }

    .badge-custom {
        background: var(--primary-light);
        color: var(--primary);
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 600;
        white-space: nowrap;
    }

    .info-grid {
        display: grid;
        gap: 8px;
    }

    .info-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .service-title {
        color: var(--primary);
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .service-table th {
        background: var(--primary-light);
        color: var(--primary);
        border: none;
    }

    .status-badge {
        background: var(--primary-light);
        color: var(--primary);
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .btn-edit,
    .btn-back {
        background: var(--primary);
        color: white;
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-edit:hover,
        .btn-back:hover {
            background: var(--primary-dark);
            color: white;
        }

    .action-buttons {
        margin-top: 25px;
    }

    @@media (max-width: 768px) {
        .details-header,
        .customer-profile,
        .aircon-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }
    }
</style>