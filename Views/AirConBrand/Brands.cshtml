@model IEnumerable<AirConServicingManagementSystem.Models.AirConBrand>
@{
    ViewData["Title"] = "Aircon Brands";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm" style="border-top: 4px solid #2c8c99;">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0" style="color: #2c8c99;">
                        <i class="fas fa-building me-2"></i>Aircon Brands
                    </h4>
                    <p class="text-muted small mb-0 mt-1">Manage all air conditioner brands in the system</p>
                </div>
                <a asp-action="CreateBrand" class="btn text-white" style="background-color: #2c8c99; border-color: #2c8c99;">
                    <i class="fas fa-plus-circle me-2"></i>Add New Brand
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light" style="background-color: #f8f9fa !important;">
                        <tr>
                            <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99;">ID</th>
                            <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99;">Brand Name</th>
                            @* <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99;">Description</th> *@
                            @* <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99;">Status</th> *@
                            <th style="color: #2c8c99; font-weight: 600; padding: 1rem; border-bottom: 2px solid #2c8c99; text-align: center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid #eee; transition: background-color 0.2s;">
                                <td class="align-middle" style="padding: 1rem; font-weight: 500;">#@item.Id</td>
                                <td class="align-middle" style="padding: 1rem;">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0 me-3">
                                            <div class="rounded-circle d-flex align-items-center justify-content-center"
                                                 style="width: 36px; height: 36px; background-color: rgba(44, 140, 153, 0.1); color: #2c8c99;">
                                                <i class="fas fa-building"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1">
                                            <span class="fw-semibold">@item.BrandName</span>
                                        </div>
                                    </div>
                                </td>
                                @* <td class="align-middle" style="padding: 1rem;">
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <span class="text-muted">@item.Description</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No description</span>
                                    }
                                </td> *@
                               @*  <td class="align-middle" style="padding: 1rem;">
                                    @if (item.IsActive == true)
                                    {
                                        <span class="badge rounded-pill d-inline-flex align-items-center"
                                              style="background-color: rgba(44, 140, 153, 0.1); color: #2c8c99; padding: 0.35rem 0.75rem;">
                                            <i class="fas fa-check-circle me-1" style="font-size: 0.75rem;"></i>
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill d-inline-flex align-items-center"
                                              style="background-color: rgba(220, 53, 69, 0.1); color: #dc3545; padding: 0.35rem 0.75rem;">
                                            <i class="fas fa-times-circle me-1" style="font-size: 0.75rem;"></i>
                                            Inactive
                                        </span>
                                    }
                                </td> *@
                                <td class="align-middle" style="padding: 1rem; text-align: center;">
                                    <div class="btn-group" role="group">
                                        <a asp-action="EditBrand" asp-route-id="@item.Id"
                                           class="btn btn-sm d-flex align-items-center justify-content-center"
                                           style="background-color: rgba(44, 140, 153, 0.1); color: #2c8c99; border: 1px solid rgba(44, 140, 153, 0.3); margin-right: 0.25rem; padding: 0.375rem 0.75rem;">
                                            <i class="fas fa-edit me-1"></i>
                                            <span class="d-none d-md-inline">Edit</span>
                                        </a>
                                        <a asp-action="DeleteBrand" asp-route-id="@item.Id"
                                           class="btn btn-sm d-flex align-items-center justify-content-center"
                                           style="background-color: rgba(220, 53, 69, 0.1); color: #dc3545; border: 1px solid rgba(220, 53, 69, 0.3); padding: 0.375rem 0.75rem;">
                                            <i class="fas fa-trash me-1"></i>
                                            <span class="d-none d-md-inline">Delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-3" style="color: #dee2e6;">
                        <i class="fas fa-building" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="text-muted mb-2">No Brands Found</h5>
                    <p class="text-muted mb-4">Add your first air conditioner brand to get started</p>
                    <a asp-action="CreateBrand" class="btn text-white" style="background-color: #2c8c99; border-color: #2c8c99;">
                        <i class="fas fa-plus-circle me-2"></i>Add First Brand
                    </a>
                </div>
            }
        </div>

        <div class="card-footer bg-white py-3 border-top">
            <div class="d-flex justify-content-between align-items-center">
                <div class="text-muted small">
                    <i class="fas fa-info-circle me-1" style="color: #2c8c99;"></i>
                    Showing <strong>@Model.Count()</strong> brand@(Model.Count() != 1 ? "s" : "")
                </div>
                <div class="small text-muted">
                    <i class="fas fa-clock me-1"></i>
                    Updated just now
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Add hover effect to table rows
            const tableRows = document.querySelectorAll('tbody tr');
            tableRows.forEach(row => {
                row.addEventListener('mouseenter', function() {
                    this.style.backgroundColor = 'rgba(44, 140, 153, 0.03)';
                });

                row.addEventListener('mouseleave', function() {
                    this.style.backgroundColor = '';
                });
            });

            // Add click effect to action buttons
            const actionButtons = document.querySelectorAll('.btn-group a');
            actionButtons.forEach(button => {
                button.addEventListener('mousedown', function() {
                    this.style.transform = 'scale(0.95)';
                });

                button.addEventListener('mouseup', function() {
                    this.style.transform = '';
                });

                button.addEventListener('mouseleave', function() {
                    this.style.transform = '';
                });
            });
        });
    </script>
}