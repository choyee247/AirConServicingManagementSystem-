@model AirConServicingManagementSystem.Models.AirConBrand
@{
    ViewData["Title"] = "Add New Brand";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm" style="border-top: 4px solid #2c8c99;">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="mb-0" style="color: #2c8c99;">Add New Brand</h4>
                <a asp-action="Brands" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to Brands
                </a>
            </div>
        </div>

        <div class="card-body">
            <form asp-action="CreateBrand" method="post" class="needs-validation" novalidate>
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-4">
                            <label asp-for="BrandName" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text" style="background-color: #f8f9fa; border-color: #dee2e6;">
                                    <i class="bi bi-tag" style="color: #2c8c99;"></i>
                                </span>
                                <input asp-for="BrandName" class="form-control" placeholder="Enter brand name" required />
                            </div>
                            <span asp-validation-for="BrandName" class="text-danger small"></span>
                        </div>

                        @* <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text" style="background-color: #f8f9fa; border-color: #dee2e6;">
                                    <i class="bi bi-card-text" style="color: #2c8c99;"></i>
                                </span>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter brand description"></textarea>
                            </div>
                        </div> *@

                       @*  <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" role="switch"
                                       style="background-color: #e9ecef; border-color: #adb5bd;"
                                       onchange="this.style.backgroundColor = this.checked ? '#2c8c99' : '#e9ecef'">
                                <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                            </div>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1" style="color: #2c8c99;"></i>
                                Active brands will be available for selection
                            </div>
                        </div> *@
                    </div>

                    <div class="col-md-4">
                        <div class="card bg-light border-0">
                            <div class="card-body">
                                <h6 class="card-title" style="color: #2c8c99;">
                                    <i class="bi bi-info-circle me-2"></i>Brand Information
                                </h6>
                                <p class="card-text small text-muted">
                                    Add a new air conditioner brand to the system. Brands help organize and categorize
                                    different air conditioner models for better service management.
                                </p>
                                <ul class="small text-muted ps-3">
                                    <li>Brand name should be unique</li>
                                    <li>Description helps identify the brand</li>
                                    <li>Active brands appear in dropdowns</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 pt-3 border-top">
                    <button type="submit" class="btn text-white" style="background-color: #2c8c99; border-color: #2c8c99;">
                        <i class="bi bi-check-circle me-2"></i>Save Brand
                    </button>
                    <button type="reset" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-clockwise me-2"></i>Reset
                    </button>
                    <a asp-action="Brands" class="btn btn-outline-secondary ms-auto">
                        <i class="bi bi-x-circle me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Form validation styling
        document.addEventListener('DOMContentLoaded', function() {
            // Toggle switch color
            const toggleSwitch = document.querySelector('input[type="checkbox"][role="switch"]');
            if (toggleSwitch) {
                toggleSwitch.style.backgroundColor = toggleSwitch.checked ? '#2c8c99' : '#e9ecef';

                toggleSwitch.addEventListener('change', function() {
                    this.style.backgroundColor = this.checked ? '#2c8c99' : '#e9ecef';
                });
            }

            // Add focus styling
            const formControls = document.querySelectorAll('.form-control');
            formControls.forEach(control => {
                control.addEventListener('focus', function() {
                    this.style.borderColor = '#2c8c99';
                    this.style.boxShadow = '0 0 0 0.25rem rgba(44, 140, 153, 0.25)';
                });

                control.addEventListener('blur', function() {
                    this.style.borderColor = '#dee2e6';
                    this.style.boxShadow = 'none';
                });
            });
        });
    </script>
}