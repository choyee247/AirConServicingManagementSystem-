@model AirConServicingManagementSystem.Models.Technician
@{
    ViewData["Title"] = "Technician Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Technician Register</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #2c8c99, #5fb3be);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .register-card {
            background: #ffffff;
            border-radius: 18px;
            padding: 35px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }

        .register-title {
            text-align: center;
            font-weight: 700;
            color: #2c8c99;
            margin-bottom: 5px;
        }

        .register-subtitle {
            text-align: center;
            color: #6c757d;
            font-size: 14px;
            margin-bottom: 25px;
        }

        .form-label {
            font-weight: 600;
            color: #495057;
        }

        .form-control {
            border-radius: 10px;
            padding: 11px 14px;
        }

        .btn-register {
            background-color: #2c8c99;
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
            font-size: 16px;
        }

            .btn-register:hover {
                background-color: #257985;
            }
    </style>
</head>
<body>

    <div class="register-card">
        <h3 class="register-title">Technician Registration</h3>
        <p class="register-subtitle">Create technician account</p>

        <form asp-action="Register" method="post">
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter full name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input asp-for="Email" class="form-control" placeholder="example@email.com" />
            </div>

            <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="09xxxxxxxx" />
            </div>

            <div class="mb-4">
                <label class="form-label">Address</label>
                <input asp-for="Address" class="form-control" placeholder="Technician address" />
            </div>

            <button type="submit" class="btn btn-register w-100 text-white">
                Register Technician
            </button>
        </form>
    </div>

</body>
</html>
